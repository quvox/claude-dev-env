# =============================================================================
# Chrome/VNC コンテナ - 共有ブラウザ環境
# =============================================================================
# 複数の Claude コンテナから共有して利用する Chrome + VNC 環境
# - Google Chrome（安定版）
# - Xvfb + x11vnc + noVNC（リモートデスクトップ）
# - IBus + Mozc（日本語入力）
# =============================================================================
FROM ubuntu:24.04

# --- ビルド引数 ---
ARG USERNAME=devuser
ARG USER_UID=1500
ARG USER_GID=1500

ENV DEBIAN_FRONTEND=noninteractive
ENV USER_HOME=/home/${USERNAME}
ENV CONTAINER_USER=${USERNAME}

# --- ロケール設定 ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    locales \
    && sed -i 's/# en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen \
    && sed -i 's/# ja_JP.UTF-8/ja_JP.UTF-8/' /etc/locale.gen \
    && locale-gen \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=ja_JP.UTF-8
ENV LANGUAGE=ja_JP:ja
ENV LC_ALL=ja_JP.UTF-8

# --- システムパッケージ ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    # 基本ツール
    curl ca-certificates sudo procps \
    # VNC / ディスプレイ（TigerVNC: X サーバー内蔵 VNC でキーイベントがネイティブ）
    tigervnc-standalone-server python3-websockify openbox \
    # ターミナル / キー操作
    lxterminal xterm xclip x11-xserver-utils xdotool \
    # 日本語入力（IBus + Mozc）
    ibus ibus-mozc ibus-gtk ibus-gtk3 ibus-gtk4 \
    mozc-utils-gui dbus-x11 im-config \
    # gsettings / dconf バックエンド
    libglib2.0-bin dconf-cli dconf-gsettings-backend dbus-user-session \
    # フォント
    fonts-noto-cjk fonts-noto-cjk-extra fonts-liberation fonts-dejavu-core \
    # Chrome 依存ライブラリ
    libgtk-3-0 libgbm1 libnss3 libnspr4 libasound2t64 \
    libxss1 libatk-bridge2.0-0 libatspi2.0-0 libdrm2 \
    libxcomposite1 libxdamage1 libxrandr2 libpango-1.0-0 \
    libcairo2 libcups2 libxkbcommon0 \
    && rm -rf /var/lib/apt/lists/*

# --- Google Chrome（安定版）---
RUN curl -fsSL https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb -o /tmp/google-chrome.deb \
    && apt-get update \
    && apt-get install -y --no-install-recommends /tmp/google-chrome.deb \
    && rm -f /tmp/google-chrome.deb \
    && rm -rf /var/lib/apt/lists/*

# --- noVNC（GitHub リリースから最新版をインストール）---
# Ubuntu パッケージの noVNC 1.3.0 はブラウザ互換性の問題があるため、最新版を使用
RUN curl -fsSL https://github.com/novnc/noVNC/archive/refs/tags/v1.6.0.tar.gz -o /tmp/novnc.tar.gz \
    && rm -rf /usr/share/novnc \
    && mkdir -p /usr/share/novnc \
    && tar -xzf /tmp/novnc.tar.gz -C /usr/share/novnc --strip-components=1 \
    && rm -f /tmp/novnc.tar.gz \
    && ln -sf vnc.html /usr/share/novnc/index.html

# --- GTK IM モジュールキャッシュ更新 ---
# Ubuntu 24.04 では libgtk パッケージ名に t64 サフィックスが付く
# 実際のパスを find で検出して実行する
RUN find /usr/lib -name "gtk-query-immodules-2.0" -exec {} --update-cache \; 2>/dev/null || true
RUN find /usr/lib -name "gtk-query-immodules-3.0" -exec {} --update-cache \; 2>/dev/null || true
# GTK4 の immodules cache（Chrome --gtk-version=4 用）
RUN find /usr/lib -name "gio-querymodules" -exec sh -c 'for d in /usr/lib/*/gtk-4.0/*/; do [ -d "$d" ] && {} "$d"; done' \; 2>/dev/null || true
# ビルド時に結果を確認
RUN echo "=== GTK3 immodules cache ===" && grep -c ibus /usr/lib/x86_64-linux-gnu/gtk-3.0/3.0.0/immodules.cache 2>/dev/null && echo "ibus entries found" || echo "WARNING: ibus not in GTK3 cache"

# --- D-Bus machine-id（gsettings に必要）---
RUN dbus-uuidgen > /var/lib/dbus/machine-id 2>/dev/null || true

# --- ユーザー作成（UID/GID はホストと一致させる）---
RUN if getent group ${USER_GID} >/dev/null 2>&1; then \
        EXISTING_GROUP=$(getent group ${USER_GID} | cut -d: -f1); \
        if [ "$EXISTING_GROUP" != "${USERNAME}" ]; then \
            groupmod -g 9999 "$EXISTING_GROUP" 2>/dev/null || true; \
        fi; \
    fi \
    && if getent passwd ${USER_UID} >/dev/null 2>&1; then \
        EXISTING_USER=$(getent passwd ${USER_UID} | cut -d: -f1); \
        if [ "$EXISTING_USER" != "${USERNAME}" ]; then \
            usermod -u 9999 "$EXISTING_USER" 2>/dev/null || true; \
        fi; \
    fi \
    && groupadd -g ${USER_GID} ${USERNAME} 2>/dev/null || true \
    && useradd -m -u ${USER_UID} -g ${USER_GID} -s /bin/bash ${USERNAME} 2>/dev/null || true \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers \
    && mkdir -p ${USER_HOME}/.claude \
    && chown ${USERNAME}:${USERNAME} ${USER_HOME}/.claude

# --- im-config で IBus をデフォルト入力メソッドに登録 ---
RUN su ${USERNAME} -c "im-config -n ibus" 2>/dev/null || true

# --- IME トグルスクリプト ---
RUN cat > /usr/local/bin/toggle-ime << 'TOGGLEEOF'
#!/bin/bash
# DBUS_SESSION_BUS_ADDRESS を取得（openbox キーバインドから呼ばれると未設定の場合がある）
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    # 方法1: ibus-daemon のプロセス環境から取得
    IBUS_PID=$(pgrep -u "$(whoami)" -f ibus-daemon 2>/dev/null | head -1)
    if [ -n "$IBUS_PID" ] && [ -r "/proc/$IBUS_PID/environ" ]; then
        DBUS_SESSION_BUS_ADDRESS=$(tr '\0' '\n' < "/proc/$IBUS_PID/environ" 2>/dev/null | grep '^DBUS_SESSION_BUS_ADDRESS=' | cut -d= -f2-)
        export DBUS_SESSION_BUS_ADDRESS
    fi
    # 方法2: openbox のプロセス環境から取得
    if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
        OB_PID=$(pgrep -u "$(whoami)" -f openbox 2>/dev/null | head -1)
        if [ -n "$OB_PID" ] && [ -r "/proc/$OB_PID/environ" ]; then
            DBUS_SESSION_BUS_ADDRESS=$(tr '\0' '\n' < "/proc/$OB_PID/environ" 2>/dev/null | grep '^DBUS_SESSION_BUS_ADDRESS=' | cut -d= -f2-)
            export DBUS_SESSION_BUS_ADDRESS
        fi
    fi
fi

# DISPLAY を確実に設定
if [ -z "$DISPLAY" ]; then
    export DISPLAY=:99
fi

# フォーカスウィンドウを記憶
FOCUSED_WIN=$(xdotool getactivewindow 2>/dev/null)

current=$(ibus engine 2>/dev/null)
if [ "$current" = "mozc-jp" ]; then
    ibus engine xkb:us::eng
else
    ibus engine mozc-jp
    # Mozc は初回起動時「直接入力」モードになるため、
    # フォーカスを元のウィンドウに戻してから Zenkaku_Hankaku を送信し
    # ひらがなモードに切り替える
    sleep 0.3
    if [ -n "$FOCUSED_WIN" ]; then
        xdotool windowfocus --sync "$FOCUSED_WIN" 2>/dev/null
    fi
    xdotool key --clearmodifiers Zenkaku_Hankaku 2>/dev/null || true
fi
TOGGLEEOF
RUN chmod +x /usr/local/bin/toggle-ime

# --- openbox 設定（右クリックメニュー + Ctrl+\ キーバインド）---
RUN mkdir -p ${USER_HOME}/.config/openbox \
    && cat > ${USER_HOME}/.config/openbox/menu.xml << 'MENU_EOF'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="Menu">
    <item label="Chrome"><action name="Execute"><execute>google-chrome-stable --no-sandbox --disable-gpu --disable-software-rasterizer --disable-dev-shm-usage --no-first-run --no-default-browser-check</execute></action></item>
    <item label="Terminal"><action name="Execute"><execute>lxterminal</execute></action></item>
    <separator />
    <item label="Toggle IME (Ctrl+\\ / F3)"><action name="Execute"><execute>toggle-ime</execute></action></item>
    <item label="IBus Setup"><action name="Execute"><execute>ibus-setup</execute></action></item>
  </menu>
</openbox_menu>
MENU_EOF
RUN cat > ${USER_HOME}/.config/openbox/rc.xml << 'RCEOF'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <keyboard>
    <keybind key="C-backslash">
      <action name="Execute"><execute>toggle-ime</execute></action>
    </keybind>
    <keybind key="F3">
      <action name="Execute"><execute>toggle-ime</execute></action>
    </keybind>
  </keyboard>
  <mouse>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu"><menu>root-menu</menu></action>
      </mousebind>
    </context>
  </mouse>
</openbox_config>
RCEOF
RUN chown -R ${USERNAME}:${USERNAME} ${USER_HOME}/.config

# --- 環境変数 ---
ENV DISPLAY=:99
ENV GTK_IM_MODULE=ibus
ENV QT_IM_MODULE=ibus
ENV XMODIFIERS=@im=ibus
ENV IBUS_ENABLE_SYNC_MODE=1

# --- エントリポイント ---
COPY scripts/entrypoint-chrome.sh /usr/local/bin/entrypoint-chrome.sh
RUN chmod +x /usr/local/bin/entrypoint-chrome.sh

EXPOSE 6080

ENTRYPOINT ["/usr/local/bin/entrypoint-chrome.sh"]
