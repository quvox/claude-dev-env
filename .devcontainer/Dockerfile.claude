# =============================================================================
# Claude Code コンテナ
# =============================================================================
# ベース: Ubuntu 24.04
# 言語: Node.js (fnm), Python3 (venv), Go, Rust
# ツール: git, tmux, zsh, vim, make, gcc, curl, wget, etc.
# Claude Code CLI
# ブラックリスト方式ファイアウォール
# 認証情報はボリュームマウントで管理
# =============================================================================
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# --- ユーザー名・パスを先に定義（全体で参照する）---
# USERNAME はビルド時に --build-arg で上書き可能（デフォルト: devuser）
ARG USERNAME=devuser
ARG USER_UID=1500
ARG USER_GID=1500
ENV USER_HOME=/home/${USERNAME}

# --- システムパッケージ ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    # ファイアウォール
    iptables ipset dnsutils \
    # シェル・ターミナル
    zsh tmux vim \
    # VCS
    git git-lfs git-secrets \
    # ネットワーク
    curl wget jq ca-certificates \
    iproute2 net-tools iputils-ping \
    # ビルドツール
    make gcc g++ pkg-config \
    # sudo・プロセス管理
    sudo procps \
    # Python 3
    python3 python3-pip python3-venv python3-dev \
    # サンドボックス（Claude Code 推奨）
    bubblewrap socat \
    # Chromium / Playwright 依存パッケージ（chromium-browser は Ubuntu 24.04 で snap 専用のため除外）
    fonts-liberation fonts-noto-cjk fonts-noto-color-emoji \
    libasound2t64 libatk-bridge2.0-0 libatk1.0-0 libcairo2 libcups2 \
    libdbus-1-3 libdrm2 libgbm1 libglib2.0-0 libgtk-3-0 libnspr4 \
    libnss3 libpango-1.0-0 libx11-6 libxcomposite1 libxdamage1 \
    libxext6 libxfixes3 libxrandr2 libxshmfence1 libxkbcommon0 \
    xdg-utils \
    # その他
    unzip xz-utils gnupg locales \
    && rm -rf /var/lib/apt/lists/*

# --- Chromium: Playwright 経由でインストール（後段）---
# 環境変数はラッパースクリプト作成時に /etc/zsh/zshrc 等で設定する

# --- ロケール設定 ---
RUN locale-gen en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

# --- 非root ユーザー作成 ---
# GID/UID が既存のグループ/ユーザーと競合する場合は退避してから作成
RUN existing_group=$(getent group $USER_GID | cut -d: -f1); \
    if [ -n "$existing_group" ] && [ "$existing_group" != "$USERNAME" ]; then \
        groupmod -g 9999 "$existing_group"; \
    fi; \
    existing_user=$(getent passwd $USER_UID | cut -d: -f1); \
    if [ -n "$existing_user" ] && [ "$existing_user" != "$USERNAME" ]; then \
        usermod -u 9999 "$existing_user"; \
    fi; \
    groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m -s /bin/zsh $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME \
    && mkdir -p $USER_HOME/.claude \
    && mkdir -p $USER_HOME/.command_history \
    && chown -R $USERNAME:$USERNAME $USER_HOME

# =============================================================================
# 言語ランタイム（非 root ユーザーでインストール）
# =============================================================================
USER $USERNAME

# --- fnm (Node.js バージョン管理) ---
# ${USER_HOME}/.local/share/fnm に絶対パスでインストール
RUN curl -fsSL https://fnm.vercel.app/install | bash -s -- \
        --install-dir "${USER_HOME}/.local/share/fnm" --skip-shell \
    && export PATH="${USER_HOME}/.local/share/fnm:$PATH" \
    && eval "$($USER_HOME/.local/share/fnm/fnm env)" \
    && fnm install 24 \
    && fnm default 24 \
    && fnm install 22 \
    && fnm use 24

# --- Go ---
ARG GO_VERSION=1.24.1
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-$(dpkg --print-architecture).tar.gz" \
    | sudo tar -C /usr/local -xz

# --- Rust (rustup) ---
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal

# --- pnpm ---
RUN export PATH="${USER_HOME}/.local/share/fnm:$PATH" \
    && eval "$($USER_HOME/.local/share/fnm/fnm env)" \
    && corepack enable \
    && corepack prepare pnpm@latest --activate

# --- Playwright + Chromium インストール ---
# Ubuntu 24.04 では chromium-browser パッケージが snap 専用のため、
# Playwright 経由で Chromium をインストールする
RUN export PATH="${USER_HOME}/.local/share/fnm:$PATH" \
    && eval "$($USER_HOME/.local/share/fnm/fnm env)" \
    && npx -y playwright@latest install --with-deps chromium

# --- AWS CLI v2 ---
RUN curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o /tmp/awscliv2.zip \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && sudo /tmp/aws/install \
    && rm -rf /tmp/aws /tmp/awscliv2.zip

# --- Terraform ---
RUN curl -fsSL https://releases.hashicorp.com/terraform/index.json \
    | jq -r '.versions | to_entries | map(select(.value.builds[]?.os == "linux")) | last | .key' \
    | xargs -I{} curl -fsSL "https://releases.hashicorp.com/terraform/{}/terraform_{}_linux_$(dpkg --print-architecture).zip" -o /tmp/terraform.zip \
    && sudo unzip -q /tmp/terraform.zip -d /usr/local/bin \
    && rm /tmp/terraform.zip

# --- Google Cloud CLI ---
RUN curl -fsSL https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-linux-$(uname -m).tar.gz \
    | tar -xz -C ${USER_HOME} \
    && ${USER_HOME}/google-cloud-sdk/install.sh --quiet --path-update=false \
    && sudo ln -s ${USER_HOME}/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud \
    && sudo ln -s ${USER_HOME}/google-cloud-sdk/bin/gsutil /usr/local/bin/gsutil \
    && sudo ln -s ${USER_HOME}/google-cloud-sdk/bin/bq /usr/local/bin/bq

# --- zrt-tools ---
COPY --chown=$USERNAME:$USERNAME zrt-tools/ /tmp/zrt-tools/
RUN export PATH="/usr/local/go/bin:${USER_HOME}/go/bin:${PATH}" \
    && cd /tmp/zrt-tools \
    && make build \
    && sudo cp build/zrt /usr/local/bin/ \
    && rm -rf /tmp/zrt-tools

# --- Claude Code CLI (ネイティブインストーラー) ---
# 公式ドキュメント: WORKDIR /tmp でインストーラーがファイルシステム全体をスキャンするのを防ぐ
WORKDIR /tmp
RUN curl -fsSL https://claude.ai/install.sh | bash
WORKDIR /workspace

# =============================================================================
# コンテナ設定
# =============================================================================
USER root

# --- Playwright Chromium ラッパー + 環境変数（ヘッドレステスト用）---
RUN CHROMIUM_PATH=$(find ${USER_HOME}/.cache/ms-playwright -name "chrome" \( -path "*/chrome-linux/chrome" -o -path "*/chrome-linux64/chrome" \) 2>/dev/null | head -1) \
    && if [ -n "$CHROMIUM_PATH" ]; then \
        { echo '#!/bin/bash'; \
          echo 'export DBUS_SESSION_BUS_ADDRESS=disabled:'; \
          printf '"%s" --no-sandbox --disable-gpu --disable-software-rasterizer --disable-dev-shm-usage --headless "$@" 2> >(grep -v -E "dbus|DEPRECATED_ENDPOINT" >&2)\n' "$CHROMIUM_PATH"; \
        } > /usr/local/bin/chromium-browser \
        && chmod +x /usr/local/bin/chromium-browser \
        && ln -sf /usr/local/bin/chromium-browser /usr/local/bin/chromium \
        && ln -sf /usr/local/bin/chromium-browser /usr/local/bin/chrome \
        && { \
            echo ""; \
            echo "# --- claude-dev: Playwright Chromium ---"; \
            echo "export CHROME_PATH=\"${CHROMIUM_PATH}\""; \
            echo "export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=\"${CHROMIUM_PATH}\""; \
            echo "export PUPPETEER_EXECUTABLE_PATH=\"${CHROMIUM_PATH}\""; \
        } >> /etc/zsh/zshrc \
        && { \
            echo ""; \
            echo "# --- claude-dev: Playwright Chromium ---"; \
            echo "export CHROME_PATH=\"${CHROMIUM_PATH}\""; \
            echo "export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=\"${CHROMIUM_PATH}\""; \
            echo "export PUPPETEER_EXECUTABLE_PATH=\"${CHROMIUM_PATH}\""; \
        } >> /etc/bash.bashrc; \
    fi


# --- シェル初期化: PATH と fnm を設定 ---
# システム側（/etc/zsh/zshrc, /etc/bash.bashrc）に配置し、
# ~/.zshrc はユーザーカスタマイズ用としてボリュームで共有する
RUN mkdir -p /etc/zsh && { \
        echo ''; \
        echo '# --- claude-dev: PATH ---'; \
        echo 'export PATH="${HOME}/.local/share/fnm:${PATH}"'; \
        echo 'eval "$(fnm env --use-on-cd --shell zsh 2>/dev/null)"'; \
        echo 'export PATH="${HOME}/.local/bin:${HOME}/.cargo/bin:/usr/local/go/bin:${HOME}/go/bin:${PATH}"'; \
    } >> /etc/zsh/zshrc \
    && { \
        echo ''; \
        echo '# --- claude-dev: PATH ---'; \
        echo 'export PATH="${HOME}/.local/share/fnm:${PATH}"'; \
        echo 'eval "$(fnm env --use-on-cd --shell bash 2>/dev/null)"'; \
        echo 'export PATH="${HOME}/.local/bin:${HOME}/.cargo/bin:/usr/local/go/bin:${HOME}/go/bin:${PATH}"'; \
    } >> /etc/bash.bashrc

# --- デフォルト .zshrc ---
COPY .zshrc $USER_HOME/.zshrc.default
RUN chown $USERNAME:$USERNAME $USER_HOME/.zshrc.default

# --- tmux 設定 ---
COPY .devcontainer/tmux.conf /etc/tmux.conf

# --- スクリプト設置 ---
COPY scripts/init-firewall-claude.sh /usr/local/bin/init-firewall.sh
COPY scripts/entrypoint-claude.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/init-firewall.sh /usr/local/bin/entrypoint.sh

# --- 作業ディレクトリ ---
RUN mkdir -p /workspace && chown $USERNAME:$USERNAME /workspace
WORKDIR /workspace

# --- Claude Code 設定 ---
RUN mkdir -p $USER_HOME/.claude \
    && echo '{"permissions":{"defaultMode":"bypassPermissions"}}' \
       > $USER_HOME/.claude/settings.json \
    && chown -R $USERNAME:$USERNAME $USER_HOME/.claude

# --- デフォルトシェル ---
ENV SHELL=/bin/zsh

# USERNAME を環境変数として保存（entrypoint で参照）
ENV CONTAINER_USER=${USERNAME}

# root で起動し、entrypoint が UID/GID 調整後にユーザーへ切り替える
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
