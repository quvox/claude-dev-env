# =============================================================================
# Samba ファイル共有コンテナ
# =============================================================================
# ワークスペースをネットワーク経由で共有
# =============================================================================
FROM alpine:3.21

RUN apk add --no-cache samba shadow

COPY .devcontainer/samba/smb.conf /etc/samba/smb.conf
COPY .devcontainer/samba/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 445

ENTRYPOINT ["/entrypoint.sh"]
