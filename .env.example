# =============================================================================
# claude-dev 設定
# =============================================================================
# cp .env.example .env して値を設定
# =============================================================================

# --- Samba ファイル共有 ---
# 共有するディレクトリ（プロジェクト群の親ディレクトリを指定）
# 例: /home/user/repos
SAMBA_SHARE_DIR=/home/user/repos
SAMBA_PORT=445
SAMBA_USER=claude
SAMBA_PASSWORD=claude

# --- GHCR イメージ配布（claude-dev pull で使用。設計 docs/10_ghcr-images.md）---
# pull 元レジストリ/オーナー（既定: ghcr.io/quvox）
CLAUDE_DEV_REGISTRY=ghcr.io/quvox
# pull するタグ（既定: latest。特定ビルドに固定するなら YYYYMMDDHHmm を指定）
CLAUDE_DEV_IMAGE_TAG=latest
