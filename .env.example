# =============================================================================
# claude-dev 設定
# =============================================================================
# cp .env.example .env して値を設定
# =============================================================================

# --- Samba ファイル共有 ---
# 共有するディレクトリ（プロジェクト群の親ディレクトリを指定）
# 例: /home/user/repos
SAMBA_SHARE_DIR=/home/user/repos
SAMBA_PORT=445
SAMBA_USER=claude
SAMBA_PASSWORD=claude
