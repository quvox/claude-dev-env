#!/bin/bash
# =============================================================================
# claude-dev - Claude Code 安全開発環境 CLI
# =============================================================================
# 任意のプロジェクトディレクトリで claude-dev start するだけで
# コンテナ隔離された Claude Code 環境が起動する
# =============================================================================
set -e

# --- パス解決 ---
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0")"
BASE_DIR="$(dirname "$SCRIPT_PATH")"
CONFIG_FILE="${BASE_DIR}/.env"

# --- 設定読み込み ---
if [ -f "$CONFIG_FILE" ]; then
    set -a
    source "$CONFIG_FILE"
    set +a
fi

# --- Docker CLI の "What's next:" ヒントを抑制 ---
# docker run / exec 後（tmux から抜けた時など）に出るプロモ表示を止める。
# 利用者が明示設定していればそれを尊重する。
export DOCKER_CLI_HINTS="${DOCKER_CLI_HINTS:-false}"

# --- 定数 ---
NETWORK="claude-dev-net"
NOVNC_BASE_PORT=6080   # noVNC ポート開始番号
FWD_PORT_BASE=8100     # ポートフォワード用開始番号
VOL_AUTH="claude-dev-auth"
VOL_HISTORY="claude-dev-history"
VOL_CONFIG="claude-dev-config"
# Chrome プロファイルはコンテナごとに分離する（共有すると複数コンテナ同時起動時に
# 同一プロファイルへ多重書き込みし SingletonLock 奪取・プロファイル破損を招く）。
# 実体は `${VOL_CHROME_PREFIX}-<container_name>`（VM ボリューム claude-dev-vm-<name> と同方式）。
VOL_CHROME_PREFIX="claude-dev-chrome"
IMG_CLAUDE="claude-dev-claude"
IMG_CLAUDE_VNC="claude-dev-claude-vnc"
IMG_DOCKER_PROXY="claude-dev-docker-proxy"
DOCKER_PROXY_CONTAINER="claude-dev-docker-proxy"

# --- コンテナ内ユーザー名 ---
# 実行するイメージに焼き込まれた CONTAINER_USER を優先する（GHCR の generic user=dev 対応）。
# イメージが無ければホストの whoami にフォールバック（ローカルビルド運用は従来どおり＝後方互換）。
CUSER="$(docker image inspect "$IMG_CLAUDE" --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null | sed -n 's/^CONTAINER_USER=//p' | head -1)"
[ -n "$CUSER" ] || CUSER="$(whoami)"
CHOME="/home/${CUSER}"

# 起動中コンテナへ exec する際のユーザーは、ローカルイメージのタグではなく「そのコンテナ自身に
# 焼き込まれた CONTAINER_USER」から解決する。make build 等でローカルイメージのユーザーが変わっても
# （例: GHCR=dev とローカルビルド=<whoami> の混在）、別イメージ由来で稼働中のコンテナへ正しい -u で
# attach できる。見つからなければ CUSER（イメージ由来）へフォールバック。
resolve_container_user() {
    local _u
    _u="$(docker inspect "$1" --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null | sed -n 's/^CONTAINER_USER=//p' | head -1)"
    [ -n "$_u" ] || _u="$CUSER"
    printf '%s' "$_u"
}

# =============================================================================
# ヘルパー関数
# =============================================================================

# --- 設定/作業ディレクトリ ---
DEV_DIR="${HOME}/.claude-dev"
DEV_AGENT_DIR="${DEV_DIR}/agents"               # プロジェクト専用 ssh-agent のソケット/PID 置き場
PROJECT_CONFIG_NAME=".claude-dev.yaml"          # プロジェクト直下の設定ファイル名（このプロジェクトで使う SSH 鍵）

# 指定した YAML ファイルの ssh_keys: セクションを SSH_KEY_LIST に読み込む（追記）
# 簡易パース: `ssh_keys:` 開始 → `- path` を読み、`~` を $HOME 展開・コメント除去
_parse_ssh_keys_yaml() {
    local config="$1"
    [ -f "$config" ] || return 0
    local line in_section=0
    while IFS= read -r line; do
        case "$line" in \#*|"") continue ;; esac
        if [[ "$line" =~ ^ssh_keys: ]]; then in_section=1; continue; fi
        if [[ $in_section -eq 1 && "$line" =~ ^[a-zA-Z_] ]]; then break; fi
        if [[ $in_section -eq 1 && "$line" =~ ^[[:space:]]*-[[:space:]]+(.*) ]]; then
            local val="${BASH_REMATCH[1]}"
            val="${val%%#*}"
            val="$(echo "$val" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            val="${val/#\~/$HOME}"
            [ -n "$val" ] && SSH_KEY_LIST+=("$val")
        fi
    done < "$config"
}

# 使う鍵リストを <project_dir>/.claude-dev.yaml の ssh_keys からのみ読み込む。
# グローバル設定へのフォールバックや自動生成は行わない（ローカル設定だけを見る）。
# 採用元は SSH_CONFIG_SOURCE に記録する。
load_ssh_keys_from_config() {
    local project_dir="${1:-$PWD}"
    local project_config="${project_dir}/${PROJECT_CONFIG_NAME}"
    SSH_KEY_LIST=()
    SSH_CONFIG_SOURCE="$project_config"
    _parse_ssh_keys_yaml "$project_config"
}

# ~/.ssh/id_*（.pub 除く）を DISCOVERED_KEYS に列挙
discover_ssh_keys() {
    DISCOVERED_KEYS=()
    local f
    for f in "$HOME"/.ssh/id_*; do
        case "$f" in *.pub) continue ;; esac
        [ -f "$f" ] && DISCOVERED_KEYS+=("$f")
    done
}

# 選択鍵をプロジェクト直下の .claude-dev.yaml に書き出す（引数=ファイルパス, 鍵パス群）
write_project_ssh_keys() {
    local file="$1"; shift
    {
        echo "# claude-dev プロジェクト設定（このプロジェクトで使う SSH 鍵。claude-dev が管理します）"
        echo "# 再選択は 'claude-dev ssh-keys'、初期化は 'claude-dev ssh-keys reset'"
        echo "ssh_keys:"
        local k
        for k in "$@"; do echo "  - $k"; done
    } > "$file"
}

# ~/.ssh の鍵を対話選択し、カレントプロジェクトの .claude-dev.yaml に保存。SSH_KEY_LIST にも反映
select_ssh_keys_interactive() {
    local file="$(pwd)/${PROJECT_CONFIG_NAME}"
    discover_ssh_keys
    if [ ${#DISCOVERED_KEYS[@]} -eq 0 ]; then
        echo "⚠️  ~/.ssh に鍵ファイル（id_*）が見つかりません。SSH 転送なしで続行します。"
        write_project_ssh_keys "$file"
        SSH_KEY_LIST=()
        return 0
    fi
    echo "利用可能な SSH 鍵:"
    local i=1 k
    for k in "${DISCOVERED_KEYS[@]}"; do echo "  $i) $k"; i=$((i + 1)); done
    printf "このプロジェクトで使う鍵を選択 (番号をカンマ/空白区切り, a=全部, n=なし): "
    local ans=""; read -r ans || ans=""
    local chosen=() tok
    case "$ans" in
        a|A|all|ALL) chosen=("${DISCOVERED_KEYS[@]}") ;;
        n|N|none|NONE|"") chosen=() ;;
        *)
            for tok in $(echo "$ans" | tr ',' ' '); do
                case "$tok" in ''|*[!0-9]*) continue ;; esac
                if [ "$tok" -ge 1 ] && [ "$tok" -le ${#DISCOVERED_KEYS[@]} ]; then
                    chosen+=("${DISCOVERED_KEYS[$((tok - 1))]}")
                fi
            done
            ;;
    esac
    write_project_ssh_keys "$file" "${chosen[@]}"
    echo "✅ SSH 鍵の選択を保存しました: $file（${#chosen[@]} 件）"
    SSH_KEY_LIST=("${chosen[@]}")
}

# プロジェクト専用 ssh-agent を起動/再利用し、解決した鍵だけを登録する。
# ホストの環境 agent は使わない（ディレクトリごとに見える鍵を隔離するため）。
# 引数: <project_dir> <name>。成功後 SSH_AUTH_SOCK を専用ソケットに固定する。
ensure_ssh_agent() {
    local project_dir="${1:-$PWD}"
    local name="${2:-default}"

    # 鍵リストを解決
    load_ssh_keys_from_config "$project_dir"

    if [ ${#SSH_KEY_LIST[@]} -eq 0 ]; then
        echo "ℹ️  SSH 鍵が未設定のため SSH 転送なしで起動します。使う鍵は ${SSH_CONFIG_SOURCE} に ssh_keys: で記述してください（例: '- ~/.ssh/id_ed25519'）"
        SSH_AUTH_SOCK=""
        return 0
    fi

    # プロジェクト専用 agent（ソケットは name ごと＝ディレクトリごと）
    mkdir -p "$DEV_AGENT_DIR"
    chmod 700 "$DEV_DIR" "$DEV_AGENT_DIR" 2>/dev/null || true
    local sock="${DEV_AGENT_DIR}/${name}.sock"
    local pidfile="${DEV_AGENT_DIR}/${name}.pid"

    # 生きている agent が無ければ起動（ssh-add -l の rc=2 は「接続不可」）
    local rc=0
    SSH_AUTH_SOCK="$sock" ssh-add -l >/dev/null 2>&1 || rc=$?
    if [ "$rc" -eq 2 ] || [ ! -S "$sock" ]; then
        rm -f "$sock"
        local out
        if ! out=$(ssh-agent -a "$sock" 2>/dev/null); then
            echo "⚠️  専用 ssh-agent の起動に失敗しました。SSH 転送なしで続行します"
            SSH_AUTH_SOCK=""
            return 0
        fi
        echo "$out" | sed -n 's/.*SSH_AGENT_PID=\([0-9][0-9]*\).*/\1/p' | head -1 > "$pidfile"
        echo "🔑 プロジェクト専用 ssh-agent を起動しました（$name）"
    fi

    # 既に登録済みの鍵の指紋（パスフレーズ再入力を避けるため突き合わせる）
    local loaded_fps
    loaded_fps="$(SSH_AUTH_SOCK="$sock" ssh-add -l 2>/dev/null | awk '{print $2}')"

    # 存在チェック → 既登録スキップ → パスフレーズなし一括 → 残りを対話追加
    local key keys=() need_passphrase=()
    for key in "${SSH_KEY_LIST[@]}"; do
        if [ ! -f "$key" ]; then
            echo "⚠️  ${key}: ファイルが見つかりません（スキップ）"
            continue
        fi
        local fp
        fp="$(ssh-keygen -lf "$key" 2>/dev/null | awk '{print $2}')"
        if [ -n "$fp" ] && printf '%s\n' "$loaded_fps" | grep -qxF "$fp"; then
            continue   # 既に登録済み
        fi
        keys+=("$key")
    done

    for key in "${keys[@]}"; do
        if SSH_AUTH_SOCK="$sock" SSH_ASKPASS=/bin/false SSH_ASKPASS_REQUIRE=force ssh-add "$key" 2>/dev/null; then
            :
        else
            need_passphrase+=("$key")
        fi
    done

    if [ ${#need_passphrase[@]} -gt 0 ]; then
        echo "🔑 パスフレーズ付きの SSH 鍵を専用 agent に追加します（初回のみ入力）:"
        for key in "${need_passphrase[@]}"; do
            SSH_AUTH_SOCK="$sock" ssh-add "$key" || echo "⚠️  ${key}: 追加できませんでした（スキップ）"
        done
    fi

    echo "🔑 SSH 鍵: ${SSH_CONFIG_SOURCE} （${#SSH_KEY_LIST[@]} 件）"
    # 以降の SSH_OPTS 組み立てが参照するソケットを専用 agent に固定
    SSH_AUTH_SOCK="$sock"
}

# プロジェクト名（カレントディレクトリから導出）
project_name() {
    basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g'
}

# コンテナ名（= ディレクトリ名）
container_name() {
    project_name
}

# イメージが存在するか
image_exists() {
    docker image inspect "$1" >/dev/null 2>&1
}

# コンテナが実行中か
is_running() {
    docker ps -q -f "name=^${1}$" 2>/dev/null | grep -q .
}

# コンテナが存在するか（停止含む）
container_exists() {
    docker ps -aq -f "name=^${1}$" 2>/dev/null | grep -q .
}

# 使用可能な noVNC ポートを探す
find_available_novnc_port() {
    local port=$NOVNC_BASE_PORT
    while [ $port -lt $((NOVNC_BASE_PORT + 100)) ]; do
        if ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${port}->"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
    done
    echo "$NOVNC_BASE_PORT"
}

# 使用可能なホストポートを探す
find_available_host_port() {
    local port=$FWD_PORT_BASE
    local max=$((FWD_PORT_BASE + 900))
    while [ $port -lt $max ]; do
        if ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${port}->"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
    done
    echo "$FWD_PORT_BASE"
}

# セットアップ済みか確認（イメージがなければ自動ビルド）
require_setup() {
    if ! image_exists "$IMG_CLAUDE"; then
        echo "📦 Claude ベースイメージが見つかりません。ビルドします..."
        docker build -t "$IMG_CLAUDE" \
            --target base \
            --build-arg USERNAME="$CUSER" \
            --build-arg USER_UID="$(id -u)" \
            --build-arg USER_GID="$(id -g)" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    fi
    if ! image_exists "$IMG_CLAUDE_VNC"; then
        echo "📦 Claude VNC イメージが見つかりません。ビルドします..."
        docker build -t "$IMG_CLAUDE_VNC" \
            --target vnc \
            --build-arg USERNAME="$CUSER" \
            --build-arg USER_UID="$(id -u)" \
            --build-arg USER_GID="$(id -g)" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    fi
}

# 起動に必要なホストコマンドを確認し、無ければ導入方法を案内して終了する。
check_host_deps() {
    local missing=() c
    for c in docker jq; do
        command -v "$c" >/dev/null 2>&1 || missing+=("$c")
    done
    [ ${#missing[@]} -eq 0 ] && return 0
    echo "❌ 起動に必要なコマンドが見つかりません: ${missing[*]}" >&2
    echo "   👉 導入してから再実行してください:" >&2
    for c in "${missing[@]}"; do
        case "$c" in
            docker) echo "      Docker Engine を導入してください（PREPARATION.md 参照）" >&2 ;;
            *)      echo "      sudo apt-get install -y $c" >&2 ;;
        esac
    done
    exit 1
}

# <project_dir>/.claude-dev.yaml が無ければ SSH 鍵選択を促し（TTY 時）、無選択/非対話
# なら ssh_keys 空配列で作成する。既存ファイルは尊重して何もしない（起動のたびに聞かない）。
ensure_project_config() {
    local project_dir="$1"
    local cfg="${project_dir}/${PROJECT_CONFIG_NAME}"
    [ -f "$cfg" ] && return 0
    if [ -t 0 ]; then
        echo "🔧 このプロジェクトに ${PROJECT_CONFIG_NAME} がありません。コンテナへ転送する SSH 鍵を選択します（不要なら n）。"
        select_ssh_keys_interactive
    else
        write_project_ssh_keys "$cfg"
        echo "🔧 ${PROJECT_CONFIG_NAME} を作成しました（ssh_keys 空＝SSH 転送なし。'claude-dev ssh-keys' で後から選択可）"
    fi
}

# Docker リソースの準備
ensure_infrastructure() {
    docker network create "$NETWORK" 2>/dev/null || true
    docker volume create "$VOL_AUTH" >/dev/null 2>&1 || true
    docker volume create "$VOL_HISTORY" >/dev/null 2>&1 || true
    docker volume create "$VOL_CONFIG" >/dev/null 2>&1 || true
    # Chrome プロファイルはコンテナごとのボリューム（docker run が自動作成）なのでここでは作らない
}

# 指定コンテナの noVNC URL を取得
get_novnc_url() {
    local port
    port=$(docker port "$1" 6080 2>/dev/null | head -1 | sed 's/.*://')
    if [ -n "$port" ]; then
        echo "http://localhost:${port}/vnc.html?autoconnect=true"
    fi
}

# 指定イメージ（または image ID）のバージョン表記を返す
# org.opencontainers.image.version ラベル優先（CI=YYYYMMDDHHmm / ローカル=local）、
# 無ければ unknown。あわせて短縮 ID と作成日時を付す。
image_version() {
    local ref="$1" v id created
    v=$(docker image inspect "$ref" --format '{{index .Config.Labels "io.github.quvox.claude-dev.version"}}' 2>/dev/null)
    id=$(docker image inspect "$ref" --format '{{.Id}}' 2>/dev/null | sed 's/^sha256://' | cut -c1-12)
    created=$(docker image inspect "$ref" --format '{{.Created}}' 2>/dev/null | cut -c1-16 | tr 'T' ' ')
    case "$v" in ""|"<no value>") v="unknown" ;; esac
    echo "${v} (id ${id}, built ${created})"
}

# Claude コンテナが 0 なら Docker Proxy コンテナを停止
stop_proxy_if_idle() {
    local count
    count=$(docker ps --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q 2>/dev/null | wc -l)
    if [ "$count" -eq 0 ]; then
        if is_running "$DOCKER_PROXY_CONTAINER"; then
            docker rm -f "$DOCKER_PROXY_CONTAINER" >/dev/null
            echo "🐳 Docker Socket Proxy コンテナを停止しました（Claude コンテナなし）"
        fi
    fi
}

# Docker Socket Proxy 共有コンテナを起動（未起動の場合のみ）
ensure_docker_proxy_container() {
    # Docker ソケットがなければスキップ
    if [ ! -S /var/run/docker.sock ]; then
        return 0
    fi

    # イメージがなければビルド
    if ! image_exists "$IMG_DOCKER_PROXY"; then
        echo "📦 Docker Socket Proxy イメージが見つかりません。ビルドします..."
        docker build -t "$IMG_DOCKER_PROXY" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.docker-proxy" "$BASE_DIR"
    fi

    # 既に実行中なら何もしない
    if is_running "$DOCKER_PROXY_CONTAINER"; then
        return 0
    fi

    # 停止中のコンテナがあれば削除
    if container_exists "$DOCKER_PROXY_CONTAINER"; then
        docker rm -f "$DOCKER_PROXY_CONTAINER" >/dev/null
    fi

    # /workspace 配下 bind の許可（既定有効・docs/03 §5 / docs/impl/50）。
    # 無効化は host 環境で CLAUDE_DEV_ALLOW_WORKSPACE_BINDS=0 を設定し proxy を作り直す。
    docker run -d \
        --name "$DOCKER_PROXY_CONTAINER" \
        --hostname "$DOCKER_PROXY_CONTAINER" \
        --network "$NETWORK" \
        --restart unless-stopped \
        -e "CLAUDE_DEV_ALLOW_WORKSPACE_BINDS=${CLAUDE_DEV_ALLOW_WORKSPACE_BINDS:-1}" \
        -v /var/run/docker.sock:/var/run/docker.sock:ro \
        "$IMG_DOCKER_PROXY" >/dev/null

    echo "🐳 Docker Socket Proxy コンテナ起動"
}

# =============================================================================
# コマンド
# =============================================================================
case "${1:-help}" in

# -----------------------------------------------------------------------------
# 初回セットアップ
# -----------------------------------------------------------------------------
setup)
    echo "🚀 Claude Code 開発環境セットアップ"
    echo ""

    # .env
    if [ ! -f "${BASE_DIR}/.env" ]; then
        cp "${BASE_DIR}/.env.example" "${BASE_DIR}/.env"
        echo "✅ .env を作成しました（必要に応じて ${BASE_DIR}/.env を編集）"
    else
        echo "ℹ️  .env は既に存在します"
    fi

    # ネットワーク
    docker network create "$NETWORK" 2>/dev/null || true
    echo "✅ ネットワーク: $NETWORK"

    # ボリューム
    docker volume create "$VOL_AUTH" >/dev/null 2>&1 || true
    docker volume create "$VOL_HISTORY" >/dev/null 2>&1 || true
    docker volume create "$VOL_CONFIG" >/dev/null 2>&1 || true
    # Chrome プロファイルはコンテナごとのボリューム（起動時に docker run が自動作成）
    echo "✅ ボリューム: $VOL_AUTH, $VOL_HISTORY, $VOL_CONFIG"

    # Claude ベースイメージビルド
    echo ""
    echo "📦 Claude ベースイメージをビルド中... (user: $CUSER)"
    docker build -t "$IMG_CLAUDE" \
        --target base \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude ベースイメージビルド完了"

    # Claude VNC イメージビルド
    echo ""
    echo "📦 Claude VNC イメージをビルド中..."
    docker build -t "$IMG_CLAUDE_VNC" \
        --target vnc \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude VNC イメージビルド完了"

    # Docker Socket Proxy イメージビルド
    echo ""
    echo "📦 Docker Socket Proxy イメージをビルド中..."
    docker build -t "$IMG_DOCKER_PROXY" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.docker-proxy" "$BASE_DIR"
    echo "✅ Docker Socket Proxy イメージビルド完了"

    echo ""
    echo "============================================"
    echo "✅ セットアップ完了！"
    echo ""
    echo "次のステップ:"
    echo "  1. claude-dev login"
    echo "  2. cd /path/to/your/project"
    echo "  3. claude-dev start"
    echo ""
    if ! command -v claude-dev >/dev/null 2>&1; then
        echo "PATH に追加:"
        echo "  sudo ln -sf ${BASE_DIR}/claude-dev /usr/local/bin/claude-dev"
    fi
    echo "============================================"
    ;;

# -----------------------------------------------------------------------------
# OAuth ログイン
# -----------------------------------------------------------------------------
login)
    require_setup
    ensure_infrastructure
    echo "📋 Claude OAuth ログイン"
    echo ""
    echo "Claude Code が起動します。ログインを完了してから /exit で終了してください。"
    echo ""

    # claude-dev-auth ボリュームを ~/.claude-shared にマウント
    # 認証ファイル（.credentials.json, .claude.json）だけを共有ボリュームに永続化
    # settings.json は共有しない（コンテナごとに独立管理）
    docker run --rm -it \
        --network "$NETWORK" \
        --entrypoint bash \
        -e "TERM=${TERM:-xterm-256color}" \
        -e "LANG=en_US.UTF-8" \
        -e "CUSER=$CUSER" \
        -e "CHOME=$CHOME" \
        -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
        "$IMG_CLAUDE" \
        -c '
            chown -R "$CUSER":"$CUSER" "$CHOME/.claude-shared" 2>/dev/null || true
            mkdir -p "$CHOME/.claude"
            chown "$CUSER":"$CUSER" "$CHOME/.claude"

            # settings.json はローカルに作成（共有しない）
            # この -c スクリプト全体がホスト側でシングルクォートに括られているため、
            # 内部でシングルクォートを使うと外側の引用が閉じて JSON が壊れる（ブレース展開）
            if [ ! -f "$CHOME/.claude/settings.json" ]; then
                echo "{\"permissions\":{\"defaultMode\":\"bypassPermissions\"},\"model\":\"sonnet\"}" > "$CHOME/.claude/settings.json"
                chown "$CUSER":"$CUSER" "$CHOME/.claude/settings.json"
            fi

            su "$CUSER" -s /bin/bash -l -c "
                # 共有ボリュームに認証情報があれば ~/.claude/ にコピー
                for f in .credentials.json .claude.json; do
                    if [ -f ~/.claude-shared/\$f ]; then
                        cp ~/.claude-shared/\$f ~/.claude/\$f
                    fi
                done
                # ~/.claude.json（ホーム直下）へのリンク
                if [ -f ~/.claude/.claude.json ]; then
                    ln -sf ~/.claude/.claude.json ~/.claude.json
                fi

                claude || true

                # login 後: 認証ファイルを共有ボリュームに永続化
                for f in .credentials.json .claude.json; do
                    src=~/.claude/\$f
                    dst=~/.claude-shared/\$f
                    if [ -f \"\$src\" ]; then
                        cp \"\$src\" \"\$dst\"
                    fi
                done
                # ホーム直下の .claude.json も確認
                if [ -f ~/.claude.json ] && [ ! -L ~/.claude.json ]; then
                    cp ~/.claude.json ~/.claude-shared/.claude.json
                fi
            "
        '

    echo "✅ ログイン処理完了"
    ;;

# -----------------------------------------------------------------------------
# ログイン情報削除
# -----------------------------------------------------------------------------
logout)
    require_setup
    echo "🗑️  認証情報を削除中..."
    # auth ボリューム（= ~/.claude-shared/）をクリア
    # 実行中のコンテナがあるとボリュームが使用中なので先に停止
    echo "   実行中のコンテナを停止中..."
    docker ps -a --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q | xargs -r docker rm -f 2>/dev/null || true
    # Docker Socket Proxy コンテナも停止
    if container_exists "$DOCKER_PROXY_CONTAINER"; then
        docker rm -f "$DOCKER_PROXY_CONTAINER" >/dev/null 2>&1 || true
    fi
    # ボリュームを空にする
    docker run --rm --entrypoint bash \
        -v "${VOL_AUTH}:/auth" \
        "$IMG_CLAUDE" \
        -c "rm -rf /auth/* /auth/.*" 2>/dev/null || true
    echo "✅ 認証情報を削除しました"
    echo "   再ログイン: claude-dev login"
    ;;

# -----------------------------------------------------------------------------
# GHCR からイメージを取得してローカル名に retag（ビルドの代わりに使う）
#   claude-dev pull [TAG]
#   .env の CLAUDE_DEV_REGISTRY（既定 ghcr.io/quvox）/ CLAUDE_DEV_IMAGE_TAG（既定 latest）を参照。
#   引数 TAG で latest 以外（YYYYMMDDHHmm）に固定できる。
# -----------------------------------------------------------------------------
pull)
    REG="${CLAUDE_DEV_REGISTRY:-ghcr.io/quvox}"
    TAG="${2:-${CLAUDE_DEV_IMAGE_TAG:-latest}}"
    echo "📥 GHCR からイメージを取得します: ${REG}/{$IMG_CLAUDE,$IMG_CLAUDE_VNC,$IMG_DOCKER_PROXY}:${TAG}"
    _pull_ok=0
    for name in "$IMG_CLAUDE" "$IMG_CLAUDE_VNC" "$IMG_DOCKER_PROXY"; do
        src="${REG}/${name}:${TAG}"
        echo "  - pull ${src}"
        if docker pull "$src"; then
            docker tag "$src" "${name}:latest"
            echo "    → ローカル名 ${name} に retag"
            _pull_ok=1
        else
            echo "    ⚠️  ${src} の取得に失敗（存在しない/未ログイン/権限？）"
        fi
    done
    if [ "$_pull_ok" = "1" ]; then
        echo "✅ pull 完了。'claude-dev start' はこのイメージを使います（再ビルドしません）"
        echo "   固定バージョンは 'claude-dev pull <YYYYMMDDHHmm>' か .env の CLAUDE_DEV_IMAGE_TAG"
    else
        echo "❌ すべての pull に失敗しました。private リポジトリなら 'docker login ghcr.io' が必要です"
        exit 1
    fi
    ;;

# -----------------------------------------------------------------------------
# プロジェクト開始（カレントディレクトリ）
# -----------------------------------------------------------------------------
start)
    check_host_deps
    require_setup
    NAME=$(container_name)
    PROJECT_DIR="$(pwd)"
    ensure_project_config "$PROJECT_DIR"
    shift || true

    # フラグ解析
    USE_VNC=1
    USE_KVM=0
    USE_VM=0
    USE_VM_FRESH=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --no-vnc) USE_VNC=0 ;;
            --kvm) USE_KVM=1 ;;
            --vm) USE_VM=1; USE_KVM=1 ;;   # VM モード（--kvm を含意）
            --vm-fresh) USE_VM=1; USE_KVM=1; USE_VM_FRESH=1 ;;  # ゲストを再 provision
        esac
        shift
    done
    # VM モードは /dev/kvm 必須（TCG では実用にならないため中止。docs/impl/80 §2）
    if [ "$USE_VM" = "1" ] && [ ! -c /dev/kvm ]; then
        echo "❌ --vm はホストに /dev/kvm が必要です（見つかりません）。中止します。"
        exit 1
    fi

    # 既に実行中 → attach（tmux セッションがなければ再作成）
    if is_running "$NAME"; then
        [ "$USE_VM_FRESH" = "1" ] && echo "⚠️  --vm-fresh は稼働中コンテナには効きません。'claude-dev stop' 後に再実行するか、稼働中は 'vm rebuild'（コンテナ内）を使ってください。"
        echo "✅ ${NAME} は実行中。接続します..."
        _img_id=$(docker inspect --format '{{.Image}}' "$NAME" 2>/dev/null)
        [ -n "$_img_id" ] && echo "🏷️  イメージバージョン: $(image_version "$_img_id")"
        ensure_infrastructure
        _url=$(get_novnc_url "$NAME")
        [ -n "$_url" ] && echo "🖥️  noVNC: $_url"
        CUSER="$(resolve_container_user "$NAME")"   # 稼働中コンテナ側のユーザーで exec する
        if ! docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
            docker exec -u "$CUSER" "$NAME" tmux new-session -d -s main 2>/dev/null || true
            sleep 0.5
        fi
        if [ "${CLAUDE_DEV_NO_ATTACH:-0}" != 1 ]; then
            docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
        fi
        exit 0
    fi

    # 停止中のコンテナがあれば削除
    if container_exists "$NAME"; then
        docker rm -f "$NAME" >/dev/null
    fi

    # インフラ確認
    ensure_infrastructure

    # イメージ選択
    if [ "$USE_VNC" = "1" ]; then
        RUN_IMAGE="$IMG_CLAUDE_VNC"
    else
        RUN_IMAGE="$IMG_CLAUDE"
    fi

    # 認証ファイルを共有ボリュームから /workspace/.claude/ にコピー
    mkdir -p "${PROJECT_DIR}/.claude"
    docker run --rm \
        --entrypoint bash \
        -v "${VOL_AUTH}:/auth:ro" \
        -v "${PROJECT_DIR}/.claude:/target" \
        "$IMG_CLAUDE" -c '
            for f in .credentials.json .claude.json; do
                [ -f "/auth/$f" ] && cp "/auth/$f" "/target/$f"
            done
            chown -R '"$(id -u):$(id -g)"' /target/
        '

    # ホストの ~/.claude/settings.json から hooks / env 設定を抽出してコピー
    # （ファイル名は歴史的経緯で host-hooks.json のままだが env も含む）
    HOST_SETTINGS="${HOME}/.claude/settings.json"
    if [ -f "$HOST_SETTINGS" ]; then
        _overlay=$(jq -c '{hooks: .hooks, env: .env} | with_entries(select(.value != null))' "$HOST_SETTINGS" 2>/dev/null)
        if [ -n "$_overlay" ] && [ "$_overlay" != "{}" ]; then
            echo "$_overlay" > "${PROJECT_DIR}/.claude/host-hooks.json"
        fi
    fi

    # ホストの ~/.local/bin/ スクリプト（ユーザー独自 hook 用）をコンテナ用にコピー
    # 組み込み hook スクリプト (save_prompt.sh / sendslackmsg.sh) はイメージに焼き込み済みのため
    # ここではコピー対象外。ユーザー独自スクリプトのみ ~/.local/bin/ から運ぶ。
    if [ -d "${HOME}/.local/bin" ] && [ -n "$(ls -A "${HOME}/.local/bin/" 2>/dev/null)" ]; then
        mkdir -p "${PROJECT_DIR}/.claude/host-local-bin"
        cp -a "${HOME}/.local/bin/." "${PROJECT_DIR}/.claude/host-local-bin/"
    fi

    # .gitignore に .claude が含まれていなければ追加
    if [ -f "${PROJECT_DIR}/.gitignore" ]; then
        if ! grep -qxF '.claude' "${PROJECT_DIR}/.gitignore" && ! grep -qxF '.claude/' "${PROJECT_DIR}/.gitignore"; then
            echo '.claude' >> "${PROJECT_DIR}/.gitignore"
        fi
    elif [ -d "${PROJECT_DIR}/.git" ]; then
        echo '.claude' > "${PROJECT_DIR}/.gitignore"
    fi

    # ~/.gitconfig があればマウント（読み取り専用）
    GITCONFIG_OPT=""
    if [ -f "${HOME}/.gitconfig" ]; then
        GITCONFIG_OPT="-v ${HOME}/.gitconfig:${CHOME}/.gitconfig:ro"
    fi

    # ~/.config/gh があればマウント（読み取り専用）＝ gh の認証（hosts.yml の oauth トークン）と
    # 設定を共有し、コンテナ内でも gh が認証済みで使える。RO なのでホストの認証は書き換わらない。
    GH_CONFIG_OPT=""
    if [ -d "${HOME}/.config/gh" ]; then
        GH_CONFIG_OPT="-v ${HOME}/.config/gh:${CHOME}/.config/gh:ro"
    fi

    # Docker Socket Proxy 経由で Docker API を利用（生ソケットはマウントしない）
    DOCKER_OPTS=""
    if [ -S /var/run/docker.sock ]; then
        ensure_docker_proxy_container
        DOCKER_OPTS="-e DOCKER_HOST=tcp://${DOCKER_PROXY_CONTAINER}:2375"
    fi

    # docker compose プロジェクト名を一意化（全プロジェクトが /workspace にマウントされ
    # 既定名が "workspace" に衝突するのを防ぐ）。DOCKER_HOST と同様に -e で渡し、対話・非対話
    # を問わず全シェル（Claude Code の bash -c 実行含む）と docker exec で有効にする。
    # NAME を compose 互換名（小文字・[a-z0-9_-] のみ）へ正規化する。
    COMPOSE_PROJECT="$(printf '%s' "$NAME" | sed 's/[^a-z0-9_-]/-/g')"
    COMPOSE_OPTS="-e COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT}"

    # SSH agent 準備 & ソケット転送（秘密鍵ファイルはマウントしない）
    # プロジェクト（= NAME＝ディレクトリ）ごとに専用 agent を使い、使う鍵を切り替える
    ensure_ssh_agent "$PROJECT_DIR" "$NAME"
    SSH_OPTS=""
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
        SSH_OPTS="-v ${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:ro -e SSH_AUTH_SOCK=/tmp/ssh-agent.sock"
    fi
    # ~/.ssh/known_hosts（読み取り専用、秘密情報なし）
    if [ -f "${HOME}/.ssh/known_hosts" ]; then
        SSH_OPTS="${SSH_OPTS} -v ${HOME}/.ssh/known_hosts:${CHOME}/.ssh/known_hosts:ro"
    fi
    # ~/.ssh/config（エージェント転送用に加工した「一時コピー」を RO マウント。ホストの config は不変）
    # IdentityFile / IdentitiesOnly はコンテナ内に鍵ファイルがないため除去。
    # IdentityAgent はホスト固有の agent パスを指し、コンテナ内では SSH_AUTH_SOCK を
    # 上書きして agent を不通にするため必ず除去する。
    if [ -f "${HOME}/.ssh/config" ]; then
        _ssh_config_tmp=$(mktemp /tmp/claude-dev-ssh-config.XXXXXX)
        sed -E '/^[[:space:]]*(IdentityFile|IdentitiesOnly|IdentityAgent)/d' "${HOME}/.ssh/config" > "$_ssh_config_tmp"
        SSH_OPTS="${SSH_OPTS} -v ${_ssh_config_tmp}:${CHOME}/.ssh/config:ro"
    fi

    # noVNC ポート割り当て（VNC ありの場合のみ）
    NOVNC_PORT_OPT=""
    if [ "$USE_VNC" = "1" ]; then
        NOVNC_PORT=$(find_available_novnc_port)
        NOVNC_PORT_OPT="-p ${NOVNC_PORT}:6080 -v ${VOL_CHROME_PREFIX}-${NAME}:${CHOME}/.chrome-profile"
    fi

    # KVM / QEMU デバイス（--kvm 指定時のみ、ホストに存在すれば渡す）
    # 通常は Chrome 操作のみで十分なため既定では渡さない。
    # /dev/kvm:       CPU 仮想化
    # /dev/vhost-net: ゲスト VM の高速ネットワーク
    # /dev/net/tun:   TUN/TAP（QEMU の tap ネット等）
    KVM_OPTS=""
    if [ "$USE_KVM" = "1" ]; then
        if [ -c /dev/kvm ]; then
            KVM_OPTS="--device=/dev/kvm"
        else
            echo "⚠️  --kvm が指定されましたが、ホストに /dev/kvm がありません（KVM 加速は無効）"
        fi
        if [ -c /dev/vhost-net ]; then
            KVM_OPTS="${KVM_OPTS} --device=/dev/vhost-net"
        fi
        if [ -c /dev/net/tun ]; then
            KVM_OPTS="${KVM_OPTS} --device=/dev/net/tun"
        fi
    fi

    # VM モード（--vm）: ゲスト VM 用の永続ボリューム・環境変数を渡す（docs/impl/80 §2）
    # ゲスト qcow2/キャッシュはプロジェクトごとの名前付きボリュームに保持（同時起動時の競合回避）。
    VM_OPTS=""
    if [ "$USE_VM" = "1" ]; then
        # --vm-fresh: ゲスト用ボリュームを破棄してから作成 → 初回ブートで再 provision
        if [ "$USE_VM_FRESH" = "1" ]; then
            docker volume rm -f "claude-dev-vm-${NAME}" >/dev/null 2>&1 || true
            echo "🧹 VM ゲストディスクを破棄しました（--vm-fresh）。初回ブートで再 provision します"
        fi
        VM_OPTS="-e CLAUDE_DEV_VM=1 -v claude-dev-vm-${NAME}:${CHOME}/.claude-dev-vm"
        for _v in VM_PORTS VM_MEM VM_SMP VM_DISK VM_SWAP; do
            eval "_val=\${$_v:-}"
            [ -n "$_val" ] && VM_OPTS="$VM_OPTS -e $_v=$_val"
        done
    fi

    # コンテナ起動
    if [ "$USE_VM" = "1" ]; then
        echo "🖥️  VM モードで起動します。ゲスト VM（QEMU+virtiofs）を起動するため、通常より時間がかかります。"
        echo "    （初回は cloud image の取得と provision で数分かかります。以降は数十秒程度）"
    fi
    echo "🚀 起動中... [${NAME}] → ${PROJECT_DIR}"
    echo "🏷️  イメージ: ${RUN_IMAGE}  バージョン $(image_version "$RUN_IMAGE")"
    # docker run はポート割り当て競合に備えてリトライする。複数 claude-dev を
    # ほぼ同時に start すると find_available_novnc_port の選定〜-p バインドが競合し、
    # 双方が同じポートを選んで「port is already allocated」で失敗し得る（他プロセスに
    # よる横取りも同様）。失敗時は作成途中コンテナを掃除し、ポート競合かつ VNC 有効なら
    # 別ポートを取り直して再試行する（最大 20 回）。
    _run_attempt=0
    while :; do
        if _run_err=$(docker run -d \
            --name "$NAME" \
            --hostname "$NAME" \
            --network "$NETWORK" \
            --cap-add NET_ADMIN \
            --cap-add NET_RAW \
            --restart unless-stopped \
            -v "${PROJECT_DIR}:/workspace" \
            -v "${VOL_HISTORY}:${CHOME}/.command_history" \
            -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
            -v "${VOL_CONFIG}:${CHOME}/.config-shared" \
            -v "${BASE_DIR}/scripts/tmux.conf:${CHOME}/.tmux.conf:ro" \
            -v "${BASE_DIR}/CLAUDE.md:${CHOME}/CLAUDE.md:ro" \
            $GITCONFIG_OPT \
            $GH_CONFIG_OPT \
            $SSH_OPTS \
            $DOCKER_OPTS \
            $COMPOSE_OPTS \
            $NOVNC_PORT_OPT \
            $KVM_OPTS \
            $VM_OPTS \
            -e NODE_OPTIONS=--max-old-space-size=4096 \
            -t \
            "$RUN_IMAGE" 2>&1 >/dev/null); then
            break
        fi
        _run_attempt=$((_run_attempt + 1))
        docker rm -f "$NAME" >/dev/null 2>&1 || true   # 作成途中コンテナを掃除
        if [ "$USE_VNC" = "1" ] && [ "$_run_attempt" -le 20 ] \
           && printf '%s' "$_run_err" | grep -qiE "port is already allocated|address already in use|bind for .* failed"; then
            NOVNC_PORT=$(find_available_novnc_port)
            NOVNC_PORT_OPT="-p ${NOVNC_PORT}:6080 -v ${VOL_CHROME_PREFIX}-${NAME}:${CHOME}/.chrome-profile"
            echo "🔁 noVNC ポートが競合したため ${NOVNC_PORT} で再試行します"
            continue
        fi
        echo "❌ コンテナ起動に失敗しました:" >&2
        printf '%s\n' "$_run_err" >&2
        exit 1
    done

    # tmux 起動を待つ（VM モードはゲスト VM のブート待ちで時間がかかるため長めに待つ）
    _wait_max=30
    [ "$USE_VM" = "1" ] && _wait_max=420
    for i in $(seq 1 "$_wait_max"); do
        if docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
            break
        fi
        # VM モードは待ちが長いので進捗を表示（15 秒ごと）
        if [ "$USE_VM" = "1" ] && [ "$((i % 15))" -eq 0 ]; then
            echo "   …VM 起動待ち (${i}s / 最大 ${_wait_max}s)"
        fi
        sleep 1
    done

    # tmux がまだ上がっていなければ（VM の provision が上限時間を超過等）、
    # 無言で attach 失敗して終了せず、状況を案内する
    if ! docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
        if [ "$USE_VM" = "1" ]; then
            echo "⏳ ゲスト VM の起動がまだ完了していません（provision 継続中）。"
            echo "   コンテナは起動したままです。進捗は 'claude-dev start --vm' を再実行するか、"
            echo "   コンテナ内で 'vm logs' / 'vm status' で確認できます。準備完了後に再接続されます。"
        else
            echo "⏳ tmux セッションの起動待ちがタイムアウトしました。'claude-dev start' を再実行してください。"
        fi
        exit 0
    fi

    echo "✅ 起動完了（Ctrl-_ D で切断、claude-dev start で再接続）"
    _url=$(get_novnc_url "$NAME")
    [ -n "$_url" ] && echo "🖥️  noVNC: $_url"
    # CLAUDE_DEV_NO_ATTACH=1 のときは attach せず戻る（orchestrate がコンテナだけ
    # 起こしてから orch セッションへ attach するため）。
    if [ "${CLAUDE_DEV_NO_ATTACH:-0}" != 1 ]; then
        docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    fi
    ;;

# -----------------------------------------------------------------------------
# Claude Code を新しい tmux ウィンドウで起動
# -----------------------------------------------------------------------------
code)
    require_setup
    NAME=$(container_name)

    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません: claude-dev start を先に実行"
        exit 1
    fi
    CUSER="$(resolve_container_user "$NAME")"   # 稼働中コンテナ側のユーザーで exec する

    # VM モード時は VM_DEV.md への導線を --append-system-prompt で注入（CLAUDE.md 非侵襲）
    _claude_cmd="claude"
    if [ "$(docker exec "$NAME" printenv CLAUDE_DEV_VM 2>/dev/null)" = "1" ]; then
        _claude_cmd='claude --append-system-prompt "VM モード有効。docker はゲスト VM の daemon を指し、bind mount の source は /workspace 配下のみ有効。制御情報は /workspace/VM_DEV.md を参照。"'
    fi
    docker exec -it -u "$CUSER" "$NAME" tmux new-window -t main "$_claude_cmd"
    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# AI オーケストレーターを新しい tmux ウィンドウで起動
#   claude-dev orchestrate [<ゴール>] [--fresh]
#   ゴールは任意（既定はブレインストーミングから開始）。
#   --fresh で前回の実行状態（state/plan/control・worktree/orch ブランチ）を
#   破棄してブレインストーミングから新規開始する（中断した executing/intervening の再開を上書き）。
#   worker の実行内容はダッシュボードの [d] キーでライブ表示できる。
# -----------------------------------------------------------------------------
orchestrate)
    require_setup
    NAME=$(container_name)

    # コンテナ未起動なら、まず起動してから（attach せずに）orchestrator へ進む。
    # start の全ロジック（認証コピー/マウント/VNC/VM/tmux 起動待ち）を再利用し、
    # 最後の main への attach だけ CLAUDE_DEV_NO_ATTACH=1 で抑止する。
    if ! is_running "$NAME"; then
        echo "🚀 コンテナが未起動のため起動します（claude-dev start 相当）..."
        CLAUDE_DEV_NO_ATTACH=1 "$SCRIPT_PATH" start || { echo "❌ コンテナ起動に失敗しました"; exit 1; }
        if ! is_running "$NAME"; then
            echo "❌ コンテナが起動できませんでした（VM モードは provision に時間がかかることがあります。少し待って再実行してください）"
            exit 1
        fi
    fi

    CUSER="$(resolve_container_user "$NAME")"   # 稼働中コンテナ側のユーザーで exec する

    shift  # "orchestrate" を除去
    _fresh=""
    _goal=""
    for a in "$@"; do
        case "$a" in
            --fresh) _fresh="--fresh" ;;
            *) if [ -z "$_goal" ]; then _goal="$a"; else _goal="$_goal $a"; fi ;;
        esac
    done

    # tmux 常駐方式（docs/06 §5.9 / docs/impl/10_cli.md）。生存判定は
    # **コントローラプロセスの生存**で行う（has-session ではない）：worker/brainstorming
    # ウィンドウが remain-on-exit on のため、コントローラ〔dashboard 窓〕が死んでも
    # セッションが延命し得る（空き殻セッション）。has-session だとそれを誤って生存と
    # 判定して壊れたセッションへ attach してしまう。
    #   1) コントローラが常駐すべきメインセッション名を本体から取得
    #   2) コントローラプロセス生存 → attach のみ
    #   3) 不在 → 空き殻セッションを kill してから新 main で起こし直し（resume）→ attach
    _sess=$(docker exec -u "$CUSER" "$NAME" claude-orchestrator --print-main-session 2>/dev/null | tr -d '\r\n')
    [ -n "$_sess" ] || _sess="orch-main"

    # コントローラプロセス（claude-orchestrator --workspace）が生きているか。
    # tmux new-session ランチャの cmdline にも同文字列が載るため、cmdline が
    # claude-orchestrator で始まるプロセス（＝本体。tmux 起動ラッパを除く）だけを見る。
    _orch_alive() {
        docker exec -u "$CUSER" "$NAME" sh -c '
            for p in $(pgrep -f "claude-orchestrator --workspace" 2>/dev/null); do
                cmd=$(tr "\0" " " < /proc/$p/cmdline 2>/dev/null)
                case "$cmd" in
                    claude-orchestrator*|/*/claude-orchestrator*) exit 0 ;;
                esac
            done
            exit 1
        ' 2>/dev/null
    }

    if _orch_alive; then
        echo "↩️  コントローラは常駐中です（$_sess）。接続します"
        docker exec -it -u "$CUSER" "$NAME" tmux attach -t "$_sess"
    else
        # コントローラ不在。延命した空き殻セッションが残っていれば掃除する。
        docker exec -u "$CUSER" "$NAME" tmux kill-session -t "$_sess" 2>/dev/null || true

        # コンテナ内コマンドを組み立てる（workspace は /workspace 固定）
        _cmd="claude-orchestrator --workspace /workspace"
        [ -n "$_fresh" ] && _cmd="$_cmd $_fresh"
        if [ -n "$_goal" ]; then
            _esc=$(printf '%s' "$_goal" | sed 's/"/\\"/g')
            _cmd="$_cmd \"$_esc\""
        fi
        # VM モード: 非対話起動は rc を読まないため、ゲストの DOCKER_HOST を明示的に
        # 引き継ぐ（VM 未起動時は vm.env が無く既定の proxy 経路へフォールバック）。
        _cmd="[ -f /etc/claude-dev/vm.env ] && . /etc/claude-dev/vm.env; $_cmd"

        # コントローラ本体を main セッションの dashboard ウィンドウで常駐させる
        # （dashboard 窓は remain-on-exit off。生存判定はプロセスで行う＝上記）。
        docker exec -u "$CUSER" "$NAME" tmux new-session -d -s "$_sess" -n dashboard -c /workspace "$_cmd"
        # mouse on: worker/介入の対話 claude でホイールスクロールを使えるように
        # （耐障害性はクライアント破壊でもセッション＝コントローラ生存で担保。docs/06 §5.9）。
        # コントローラ起動時の SetupMainSession でも on を確定するが、attach 前に先行設定する。
        docker exec -u "$CUSER" "$NAME" tmux set-option -t "$_sess" mouse on
        docker exec -it -u "$CUSER" "$NAME" tmux attach -t "$_sess"
    fi
    ;;

# -----------------------------------------------------------------------------
# 既存セッションに接続
# -----------------------------------------------------------------------------
attach)
    require_setup
    if [ -n "$2" ]; then
        # 名前指定
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        echo "   実行中のセッション: claude-dev list"
        exit 1
    fi
    CUSER="$(resolve_container_user "$NAME")"   # 稼働中コンテナ側のユーザーで exec する

    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# プロジェクト停止
# -----------------------------------------------------------------------------
stop)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if container_exists "$NAME"; then
        # フォワードコンテナも停止
        docker ps -a --filter "name=^fwd-${NAME}-" -q | xargs -r docker rm -f 2>/dev/null || true
        docker rm -f "$NAME" >/dev/null
        echo "✅ ${NAME} を停止しました"
    else
        echo "ℹ️  ${NAME} は存在しません"
    fi

    # Claude コンテナが残っていなければ Docker Proxy も停止
    stop_proxy_if_idle
    ;;

# -----------------------------------------------------------------------------
# ポートフォワード（動的追加）
# -----------------------------------------------------------------------------
forward)
    if [ -z "$2" ]; then
        echo "使い方: claude-dev forward <container-port> [NAME]"
        echo "例:     claude-dev forward 3000"
        exit 1
    fi
    CPORT="$2"
    if [ -n "$3" ]; then
        NAME="$3"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        exit 1
    fi

    # 既にフォワード済みか確認
    FWD_NAME="fwd-${NAME}-${CPORT}"
    if is_running "$FWD_NAME"; then
        _hport=$(docker port "$FWD_NAME" "$CPORT" 2>/dev/null | head -1 | sed 's/.*://')
        echo "ℹ️  既にフォワード済み: host:${_hport} → ${NAME}:${CPORT}"
        exit 0
    fi
    if container_exists "$FWD_NAME"; then
        docker rm -f "$FWD_NAME" >/dev/null
    fi

    HPORT=$(find_available_host_port)
    docker run -d --rm \
        --name "$FWD_NAME" \
        --network "$NETWORK" \
        -p "${HPORT}:${CPORT}" \
        --entrypoint socat \
        "$IMG_CLAUDE" \
        "TCP-LISTEN:${CPORT},fork,reuseaddr" "TCP:${NAME}:${CPORT}" >/dev/null

    echo "✅ host:${HPORT} → ${NAME}:${CPORT}"
    echo "   SSH: ssh -O forward -L ${HPORT}:localhost:${HPORT} <server>"
    ;;

# -----------------------------------------------------------------------------
# ポートフォワード解除
# -----------------------------------------------------------------------------
unforward)
    if [ -z "$2" ]; then
        echo "使い方: claude-dev unforward <container-port> [NAME]"
        exit 1
    fi
    CPORT="$2"
    if [ -n "$3" ]; then
        NAME="$3"
    else
        NAME=$(container_name)
    fi
    FWD_NAME="fwd-${NAME}-${CPORT}"
    if container_exists "$FWD_NAME"; then
        docker rm -f "$FWD_NAME" >/dev/null
        echo "✅ ${NAME}:${CPORT} のフォワードを解除しました"
    else
        echo "ℹ️  ${NAME}:${CPORT} のフォワードはありません"
    fi
    ;;

# -----------------------------------------------------------------------------
# ポートフォワード一覧
# -----------------------------------------------------------------------------
ports)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        exit 1
    fi

    echo "📡 ${NAME} のポートフォワード:"
    _has_fwd=0
    for cid in $(docker ps --filter "name=^fwd-${NAME}-" -q 2>/dev/null); do
        _has_fwd=1
        _fwd_name=$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')
        _cport="${_fwd_name##*-}"
        _hport=$(docker port "$_fwd_name" "$_cport" 2>/dev/null | head -1 | sed 's/.*://')
        [ -n "$_hport" ] && echo "   host:${_hport} → ${NAME}:${_cport}"
    done
    [ $_has_fwd -eq 0 ] && echo "   (なし — claude-dev forward <port> で追加)"

    _url=$(get_novnc_url "$NAME")
    if [ -n "$_url" ]; then
        echo ""
        echo "🖥️  noVNC: $_url"
    fi
    ;;

# -----------------------------------------------------------------------------
# 実行中セッション一覧
# -----------------------------------------------------------------------------
list)
    echo "=== 実行中の Claude Code セッション ==="
    _has_containers=0
    for cid in $(docker ps --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q 2>/dev/null); do
        _has_containers=1
        cname=$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')
        _name="${cname}"
        _status=$(docker inspect --format '{{.State.Status}}' "$cid")
        _workspace=$(docker inspect --format '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}' "$cid")
        _novnc_url=$(get_novnc_url "$cname")
        echo ""
        echo "  NAME:      ${_name}"
        echo "  STATUS:    ${_status}"
        echo "  WORKSPACE: ${_workspace}"
        [ -n "$_novnc_url" ] && echo "  noVNC:     ${_novnc_url}"
        # フォワードコンテナを列挙
        for _fid in $(docker ps --filter "name=^fwd-${cname}-" -q 2>/dev/null); do
            _fn=$(docker inspect --format '{{.Name}}' "$_fid" | sed 's|^/||')
            _cp="${_fn##*-}"
            _hp=$(docker port "$_fn" "$_cp" 2>/dev/null | head -1 | sed 's/.*://')
            [ -n "$_hp" ] && echo "  FORWARD:   host:${_hp} → ${cname}:${_cp}"
        done
    done
    if [ $_has_containers -eq 0 ]; then
        echo "  (実行中のセッションはありません)"
    fi

    # Docker Socket Proxy コンテナの状態
    echo ""
    echo "=== Docker Socket Proxy コンテナ ==="
    if is_running "$DOCKER_PROXY_CONTAINER"; then
        echo "  STATUS:  running"
    else
        echo "  STATUS:  stopped（claude-dev start で自動起動）"
    fi

    ;;

# -----------------------------------------------------------------------------
# SSH 鍵の選択（対話）/ 初期化（対象はカレントプロジェクト）
#   claude-dev ssh-keys          鍵を対話選択して ./.claude-dev.yaml に保存
#   claude-dev ssh-keys reset    このプロジェクトの選択を初期化（./.claude-dev.yaml の ssh_keys 除去＋専用 agent 停止）
# -----------------------------------------------------------------------------
ssh-keys)
    NAME=$(container_name)
    _proj_config="$(pwd)/${PROJECT_CONFIG_NAME}"
    case "${2:-}" in
        reset)
            # カレントプロジェクトの .claude-dev.yaml から ssh_keys セクションを除去
            # （他の記述は残す。ssh_keys だけになれば空になるのでファイルごと削除）
            if [ -f "$_proj_config" ]; then
                _tmp=$(mktemp)
                grep -vE '^ssh_keys:|^[[:space:]]*-[[:space:]]|^# claude-dev プロジェクト設定|^# 再選択は' "$_proj_config" > "$_tmp" 2>/dev/null || true
                if grep -qE '[^[:space:]]' "$_tmp" 2>/dev/null; then mv "$_tmp" "$_proj_config"; else rm -f "$_tmp" "$_proj_config"; fi
            fi
            # このプロジェクトの専用 agent を停止・削除（登録済み鍵をクリア）
            _sock="${DEV_AGENT_DIR}/${NAME}.sock"
            _pid="${DEV_AGENT_DIR}/${NAME}.pid"
            [ -f "$_pid" ] && kill "$(cat "$_pid" 2>/dev/null)" 2>/dev/null || true
            rm -f "$_sock" "$_pid"
            echo "✅ このプロジェクト（${NAME}）の SSH 鍵選択をリセットしました。再設定は 'claude-dev ssh-keys' で選択するか .claude-dev.yaml を作成してください"
            ;;
        ""|select)
            select_ssh_keys_interactive
            ;;
        *)
            echo "使い方: claude-dev ssh-keys [reset]"
            exit 1
            ;;
    esac
    ;;

# -----------------------------------------------------------------------------
# Claude Code アップグレード
# -----------------------------------------------------------------------------
upgrade)
    echo "📦 Claude ベースイメージを更新中..."
    docker build --no-cache -t "$IMG_CLAUDE" \
        --target base \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude ベースイメージ更新完了"

    echo ""
    echo "📦 Claude VNC イメージを更新中..."
    docker build --no-cache -t "$IMG_CLAUDE_VNC" \
        --target vnc \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude VNC イメージ更新完了"

    echo ""
    echo "📦 Docker Socket Proxy イメージを更新中..."
    docker build --no-cache -t "$IMG_DOCKER_PROXY" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.docker-proxy" "$BASE_DIR"
    echo "✅ Docker Socket Proxy イメージ更新完了"

    echo ""
    echo "   実行中のコンテナは stop → start で反映されます"
    ;;

# -----------------------------------------------------------------------------
# ファイアウォール確認
# -----------------------------------------------------------------------------
firewall)
    NAME=$(container_name)
    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません"
        exit 1
    fi
    docker exec "$NAME" iptables -L OUTPUT -n --line-numbers
    ;;

# -----------------------------------------------------------------------------
# 全リセット
# -----------------------------------------------------------------------------
reset)
    echo "⚠️  以下を全て削除します:"
    echo "   - 全 Claude Code コンテナ"
    echo "   - Docker Socket Proxy コンテナ"
    echo "   - 認証情報・履歴ボリューム"
    echo "   - Docker イメージ"
    echo ""
    read -p "実行しますか？ (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "キャンセルしました"
        exit 0
    fi

    # プロジェクトコンテナ + フォワードコンテナ停止
    docker ps -a --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q | xargs -r docker rm -f 2>/dev/null || true
    docker ps -a --filter "name=^fwd-" -q | xargs -r docker rm -f 2>/dev/null || true
    # Docker Socket Proxy コンテナ停止
    docker rm -f "$DOCKER_PROXY_CONTAINER" 2>/dev/null || true
    # ボリューム削除（共有 3 ボリューム + コンテナごとの Chrome プロファイル `claude-dev-chrome-*`）
    docker volume rm -f "$VOL_AUTH" "$VOL_HISTORY" "$VOL_CONFIG" 2>/dev/null || true
    docker volume ls -q --filter "name=^${VOL_CHROME_PREFIX}-" | xargs -r docker volume rm -f 2>/dev/null || true
    # ネットワーク削除
    docker network rm "$NETWORK" 2>/dev/null || true
    # イメージ削除
    docker rmi -f "$IMG_CLAUDE" "$IMG_CLAUDE_VNC" "$IMG_DOCKER_PROXY" 2>/dev/null || true

    echo "✅ 全リセット完了"
    ;;

# -----------------------------------------------------------------------------
# ヘルプ
# -----------------------------------------------------------------------------
help|*)
    cat << 'EOF'
claude-dev - Claude Code 安全開発環境

セットアップ（初回のみ）:
  claude-dev setup               イメージビルド + インフラ構築
  claude-dev pull [TAG]          GHCR からビルド済みイメージを取得（ビルドの代わり。既定 latest）
  claude-dev login               OAuth ログイン
  claude-dev logout              認証情報を削除

開発:
  claude-dev start               カレントディレクトリで環境を起動（VNC + Chrome 付き）
  claude-dev start --no-vnc      Chrome / VNC なしで起動（軽量）
  claude-dev start --kvm         KVM/QEMU デバイスを渡して起動（VM を動かす時のみ）
  claude-dev code                新しい tmux ウィンドウで Claude Code を起動
  claude-dev orchestrate [<ゴール>] [--fresh]
                                 AI オーケストレーター（ブレインストーミング→自律実行）を起動
                                 （--fresh で前回の実行状態を破棄しブレインストーミングから再開）
  claude-dev attach [NAME]       既存セッションに接続
  claude-dev stop [NAME]         セッションを停止
  claude-dev list                実行中セッション一覧

SSH 鍵（カレントプロジェクトの .claude-dev.yaml）:
  claude-dev ssh-keys            使う鍵を対話選択して保存
  claude-dev ssh-keys reset      このプロジェクトの鍵選択を初期化

ポートフォワード:
  claude-dev forward <PORT> [NAME]    ポートを動的に追加
  claude-dev unforward <PORT> [NAME]  ポートフォワード解除
  claude-dev ports [NAME]             ポートフォワード一覧

メンテナンス:
  claude-dev upgrade             全イメージを更新（--no-cache 再ビルド）
  claude-dev firewall            ファイアウォールルール確認
  claude-dev reset               全削除（コンテナ・ボリューム・イメージ）

使い方:
  cd ~/repos/my-project && claude-dev start

  デフォルトでは VNC + Chrome 付きコンテナが起動します。
  --no-vnc を指定すると Chrome / VNC なしの軽量コンテナで起動します。
  --kvm を指定すると KVM/QEMU デバイス（/dev/kvm 等）を渡します（VM を動かす時のみ。既定は渡しません）。
  VNC ありの場合、noVNC URL は起動時に表示されます。
  日本語入力は Ctrl+\\ または F3 で切り替え（IBus-Mozc）。

[NAME] について:
  NAME はプロジェクトのディレクトリ名です。
  省略するとカレントディレクトリから自動判定します。
  claude-dev list で実行中セッションの NAME を確認できます。

Web アプリへのリモートアクセス:
  1. claude-dev start           → コンテナ起動
  2. claude-dev forward 3000    → ポートフォワードを動的追加
  3. クライアント PC で SSH トンネル:
     ssh -O forward -L <host-port>:localhost:<host-port> <server>
  4. ブラウザで http://localhost:<host-port> にアクセス
EOF
    ;;
esac
