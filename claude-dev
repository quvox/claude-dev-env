#!/bin/bash
# =============================================================================
# claude-dev - Claude Code 安全開発環境 CLI
# =============================================================================
# 任意のプロジェクトディレクトリで claude-dev start するだけで
# コンテナ隔離された Claude Code 環境が起動する
# =============================================================================
set -e

# --- パス解決 ---
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0")"
BASE_DIR="$(dirname "$SCRIPT_PATH")"
CONFIG_FILE="${BASE_DIR}/.env"

# --- 設定読み込み ---
if [ -f "$CONFIG_FILE" ]; then
    set -a
    source "$CONFIG_FILE"
    set +a
fi

# --- 定数 ---
NETWORK="claude-dev-net"
NOVNC_BASE_PORT=6080   # Chrome/VNC コンテナの noVNC ポート開始番号
WEBAPP_BASE_PORT=8100   # Web アプリ用ポート開始番号
WEBAPP_PORTS_PER_CONTAINER=10  # コンテナあたりのポートブロックサイズ
# コンテナ内ポート → ブロック内オフセットのマッピング
WEBAPP_DEV_PORTS=(3000 4200 5173 5000 8000 8080 8888)
WEBAPP_DEV_LABELS=("React/Next/Express/Rails" "Angular" "Vite" "Flask" "Django/FastAPI/Hugo" "Go/Spring Boot" "Jupyter")
VOL_AUTH="claude-dev-auth"
VOL_HISTORY="claude-dev-history"
VOL_CONFIG="claude-dev-config"
VOL_CHROME="claude-dev-chrome-data"
IMG_CLAUDE="claude-dev-claude"
IMG_CHROME="claude-dev-chrome"
CHROME_CONTAINER="claude-dev-chrome"

# --- コンテナ内ユーザー名（ホストのカレントユーザーに合わせる）---
CUSER="$(whoami)"
CHOME="/home/${CUSER}"

# =============================================================================
# ヘルパー関数
# =============================================================================

# ssh-agent が動いていなければ起動し、鍵が未登録なら ssh-add する
ensure_ssh_agent() {
    # agent が動いていなければ起動
    if [ -z "${SSH_AUTH_SOCK:-}" ] || [ ! -S "${SSH_AUTH_SOCK:-}" ]; then
        eval "$(ssh-agent -s)" >/dev/null
        echo "🔑 ssh-agent を起動しました"
    fi

    # 鍵が既に登録されていれば何もしない
    if ssh-add -l >/dev/null 2>&1; then
        return 0
    fi

    # ~/.ssh に秘密鍵があるか確認
    local keys=()
    for f in ~/.ssh/id_*; do
        # .pub ファイルは除外
        case "$f" in *.pub) continue ;; esac
        [ -f "$f" ] && keys+=("$f")
    done

    if [ ${#keys[@]} -eq 0 ]; then
        echo "⚠️  SSH 鍵が見つかりません（~/.ssh/id_*）。git の SSH 操作はできません"
        return 0
    fi

    # まずパスフレーズなしの鍵を自動追加
    local added=0
    local need_passphrase=()
    for key in "${keys[@]}"; do
        if SSH_ASKPASS=/bin/false SSH_ASKPASS_REQUIRE=force ssh-add "$key" 2>/dev/null; then
            added=1
        else
            need_passphrase+=("$key")
        fi
    done

    # パスフレーズ付きの鍵は対話的に追加を試みる
    if [ ${#need_passphrase[@]} -gt 0 ]; then
        echo "🔑 パスフレーズ付きの SSH 鍵があります。パスフレーズを入力してください。"
        for key in "${need_passphrase[@]}"; do
            if ssh-add "$key"; then
                added=1
            else
                echo "⚠️  ${key}: 追加できませんでした（スキップ）"
            fi
        done
    fi

    if [ "$added" -eq 0 ]; then
        echo "⚠️  SSH 鍵を追加できませんでした。手動で ssh-add を実行してから再度 claude-dev start してください"
    fi
}

# プロジェクト名（カレントディレクトリから導出）
project_name() {
    basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g'
}

# コンテナ名（= ディレクトリ名）
container_name() {
    project_name
}

# イメージが存在するか
image_exists() {
    docker image inspect "$1" >/dev/null 2>&1
}

# コンテナが実行中か
is_running() {
    docker ps -q -f "name=^${1}$" 2>/dev/null | grep -q .
}

# コンテナが存在するか（停止含む）
container_exists() {
    docker ps -aq -f "name=^${1}$" 2>/dev/null | grep -q .
}

# 使用可能な noVNC ポートを探す
find_available_novnc_port() {
    local port=$NOVNC_BASE_PORT
    while [ $port -lt $((NOVNC_BASE_PORT + 100)) ]; do
        if ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${port}->"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
    done
    echo "$NOVNC_BASE_PORT"
}

# 使用可能な Web アプリ用ポートブロックを探す（10 ポート単位）
find_available_webapp_port_block() {
    local base=$WEBAPP_BASE_PORT
    local max=$((WEBAPP_BASE_PORT + 800))  # 8100-8899
    while [ $base -lt $max ]; do
        local in_use=0
        # ブロックの先頭ポートが使用中かチェック
        if docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${base}->"; then
            in_use=1
        fi
        if [ $in_use -eq 0 ]; then
            echo "$base"
            return
        fi
        base=$((base + WEBAPP_PORTS_PER_CONTAINER))
    done
    echo "$WEBAPP_BASE_PORT"
}

# 実行中コンテナの Web アプリ用ポートブロックのベースを取得
get_webapp_base_port() {
    local port
    port=$(docker port "$1" 3000 2>/dev/null | head -1 | sed 's/.*://')
    if [ -n "$port" ]; then
        echo "$port"
    fi
}

# ポートマッピング表示
show_port_mappings() {
    local name="$1"
    local base
    base=$(get_webapp_base_port "$name")
    if [ -z "$base" ]; then
        echo "   (ポートマッピングなし)"
        return
    fi
    local i=0
    for cport in "${WEBAPP_DEV_PORTS[@]}"; do
        local hport=$((base + i))
        printf "   Host :%d → Container :%d  (%s)\n" "$hport" "$cport" "${WEBAPP_DEV_LABELS[$i]}"
        i=$((i + 1))
    done
}

# セットアップ済みか確認（イメージがなければ自動ビルド）
require_setup() {
    if ! image_exists "$IMG_CLAUDE"; then
        echo "📦 Claude イメージが見つかりません。ビルドします..."
        docker build -t "$IMG_CLAUDE" \
            --build-arg USERNAME="$CUSER" \
            --build-arg USER_UID="$(id -u)" \
            --build-arg USER_GID="$(id -g)" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    fi
}

# Docker リソースの準備
ensure_infrastructure() {
    docker network create "$NETWORK" 2>/dev/null || true
    docker volume create "$VOL_AUTH" >/dev/null 2>&1 || true
    docker volume create "$VOL_HISTORY" >/dev/null 2>&1 || true
    docker volume create "$VOL_CONFIG" >/dev/null 2>&1 || true
    docker volume create "$VOL_CHROME" >/dev/null 2>&1 || true
}

# Chrome/VNC 共有コンテナを起動（未起動の場合のみ）
ensure_chrome_container() {
    # イメージがなければビルド
    if ! image_exists "$IMG_CHROME"; then
        echo "📦 Chrome/VNC イメージが見つかりません。ビルドします..."
        docker build -t "$IMG_CHROME" \
            --build-arg USERNAME="$CUSER" \
            --build-arg USER_UID="$(id -u)" \
            --build-arg USER_GID="$(id -g)" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.chrome" "$BASE_DIR"
    fi

    # 既に実行中なら何もしない
    if is_running "$CHROME_CONTAINER"; then
        return 0
    fi

    # 停止中のコンテナがあれば削除
    if container_exists "$CHROME_CONTAINER"; then
        docker rm -f "$CHROME_CONTAINER" >/dev/null
    fi

    local novnc_port
    novnc_port=$(find_available_novnc_port)

    docker run -d \
        --name "$CHROME_CONTAINER" \
        --hostname "$CHROME_CONTAINER" \
        --network "$NETWORK" \
        --restart unless-stopped \
        -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
        -v "${VOL_CHROME}:${CHOME}/.config/google-chrome" \
        -p "${novnc_port}:6080" \
        -t \
        "$IMG_CHROME" >/dev/null

    echo "🖥️  Chrome/VNC コンテナ起動: http://localhost:${novnc_port}/vnc.html?autoconnect=true"
    echo "   日本語入力: Ctrl+\\ または F3 で切り替え"
}

# Chrome/VNC コンテナの noVNC URL を取得
get_chrome_novnc_url() {
    local port
    port=$(docker port "$CHROME_CONTAINER" 6080 2>/dev/null | head -1 | sed 's/.*://')
    if [ -n "$port" ]; then
        echo "http://localhost:${port}/vnc.html?autoconnect=true"
    fi
}

# Claude コンテナが 0 なら Chrome/VNC コンテナを停止
stop_chrome_if_idle() {
    local count
    count=$(docker ps --filter "ancestor=$IMG_CLAUDE" -q 2>/dev/null | wc -l)
    if [ "$count" -eq 0 ] && is_running "$CHROME_CONTAINER"; then
        docker rm -f "$CHROME_CONTAINER" >/dev/null
        echo "🖥️  Chrome/VNC コンテナを停止しました（Claude コンテナなし）"
    fi
}

# =============================================================================
# コマンド
# =============================================================================
case "${1:-help}" in

# -----------------------------------------------------------------------------
# 初回セットアップ
# -----------------------------------------------------------------------------
setup)
    echo "🚀 Claude Code 開発環境セットアップ"
    echo ""

    # .env
    if [ ! -f "${BASE_DIR}/.env" ]; then
        cp "${BASE_DIR}/.env.example" "${BASE_DIR}/.env"
        echo "✅ .env を作成しました（必要に応じて ${BASE_DIR}/.env を編集）"
    else
        echo "ℹ️  .env は既に存在します"
    fi

    # ネットワーク
    docker network create "$NETWORK" 2>/dev/null || true
    echo "✅ ネットワーク: $NETWORK"

    # ボリューム
    docker volume create "$VOL_AUTH" >/dev/null 2>&1 || true
    docker volume create "$VOL_HISTORY" >/dev/null 2>&1 || true
    docker volume create "$VOL_CONFIG" >/dev/null 2>&1 || true
    docker volume create "$VOL_CHROME" >/dev/null 2>&1 || true
    echo "✅ ボリューム: $VOL_AUTH, $VOL_HISTORY, $VOL_CONFIG, $VOL_CHROME"

    # Claude イメージビルド
    echo ""
    echo "📦 Claude イメージをビルド中... (user: $CUSER)"
    docker build -t "$IMG_CLAUDE" \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude イメージビルド完了"

    # Chrome/VNC イメージビルド
    echo ""
    echo "📦 Chrome/VNC イメージをビルド中..."
    docker build -t "$IMG_CHROME" \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.chrome" "$BASE_DIR"
    echo "✅ Chrome/VNC イメージビルド完了"

    echo ""
    echo "============================================"
    echo "✅ セットアップ完了！"
    echo ""
    echo "次のステップ:"
    echo "  1. claude-dev login"
    echo "  2. cd /path/to/your/project"
    echo "  3. claude-dev start"
    echo ""
    if ! command -v claude-dev >/dev/null 2>&1; then
        echo "PATH に追加:"
        echo "  sudo ln -sf ${BASE_DIR}/claude-dev /usr/local/bin/claude-dev"
    fi
    echo "============================================"
    ;;

# -----------------------------------------------------------------------------
# OAuth ログイン
# -----------------------------------------------------------------------------
login)
    require_setup
    ensure_infrastructure
    echo "📋 Claude OAuth ログイン"
    echo ""
    echo "Claude Code が起動します。ログインを完了してから /exit で終了してください。"
    echo ""

    # claude-dev-auth ボリュームを ~/.claude-shared にマウント
    # 認証ファイル（.credentials.json, .claude.json）だけを共有ボリュームに永続化
    # settings.json は共有しない（コンテナごとに独立管理）
    docker run --rm -it \
        --network "$NETWORK" \
        --entrypoint bash \
        -e "TERM=${TERM:-xterm-256color}" \
        -e "LANG=en_US.UTF-8" \
        -e "CUSER=$CUSER" \
        -e "CHOME=$CHOME" \
        -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
        "$IMG_CLAUDE" \
        -c '
            chown -R "$CUSER":"$CUSER" "$CHOME/.claude-shared" 2>/dev/null || true
            mkdir -p "$CHOME/.claude"
            chown "$CUSER":"$CUSER" "$CHOME/.claude"

            su "$CUSER" -s /bin/bash -l -c "
                # 共有ボリュームに認証情報があれば ~/.claude/ にコピー
                for f in .credentials.json .claude.json; do
                    if [ -f ~/.claude-shared/\$f ]; then
                        cp ~/.claude-shared/\$f ~/.claude/\$f
                    fi
                done
                # settings.json はローカルに作成（共有しない）
                if [ ! -f ~/.claude/settings.json ]; then
                    echo '{\"permissions\":{\"defaultMode\":\"bypassPermissions\"}}' > ~/.claude/settings.json
                fi
                # ~/.claude.json（ホーム直下）へのリンク
                if [ -f ~/.claude/.claude.json ]; then
                    ln -sf ~/.claude/.claude.json ~/.claude.json
                fi

                claude || true

                # login 後: 認証ファイルを共有ボリュームに永続化
                for f in .credentials.json .claude.json; do
                    src=~/.claude/\$f
                    dst=~/.claude-shared/\$f
                    if [ -f \"\$src\" ]; then
                        cp \"\$src\" \"\$dst\"
                    fi
                done
                # ホーム直下の .claude.json も確認
                if [ -f ~/.claude.json ] && [ ! -L ~/.claude.json ]; then
                    cp ~/.claude.json ~/.claude-shared/.claude.json
                fi
            "
        '

    echo "✅ ログイン処理完了"
    ;;

# -----------------------------------------------------------------------------
# ログイン情報削除
# -----------------------------------------------------------------------------
logout)
    require_setup
    echo "🗑️  認証情報を削除中..."
    # auth ボリューム（= ~/.claude-shared/）をクリア
    # 実行中のコンテナがあるとボリュームが使用中なので先に停止
    echo "   実行中のコンテナを停止中..."
    docker ps -a --filter "ancestor=$IMG_CLAUDE" -q | xargs -r docker rm -f 2>/dev/null || true
    # Chrome コンテナも停止
    if container_exists "$CHROME_CONTAINER"; then
        docker rm -f "$CHROME_CONTAINER" >/dev/null 2>&1 || true
    fi
    # ボリュームを空にする
    docker run --rm --entrypoint bash \
        -v "${VOL_AUTH}:/auth" \
        "$IMG_CLAUDE" \
        -c "rm -rf /auth/* /auth/.*" 2>/dev/null || true
    echo "✅ 認証情報を削除しました"
    echo "   再ログイン: claude-dev login"
    ;;

# -----------------------------------------------------------------------------
# プロジェクト開始（カレントディレクトリ）
# -----------------------------------------------------------------------------
start)
    require_setup
    NAME=$(container_name)
    PROJECT_DIR="$(pwd)"
    shift || true

    # 既に実行中 → attach（tmux セッションがなければ再作成）
    if is_running "$NAME"; then
        echo "✅ ${NAME} は実行中。接続します..."
        # Chrome/VNC コンテナも確認
        ensure_infrastructure
        ensure_chrome_container
        _url=$(get_chrome_novnc_url)
        [ -n "$_url" ] && echo "🖥️  noVNC: $_url"
        if ! docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
            docker exec -u "$CUSER" "$NAME" tmux new-session -d -s main 2>/dev/null || true
            sleep 0.5
        fi
        docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
        exit 0
    fi

    # 停止中のコンテナがあれば削除
    if container_exists "$NAME"; then
        docker rm -f "$NAME" >/dev/null
    fi

    # インフラ確認
    ensure_infrastructure

    # Chrome/VNC 共有コンテナ起動
    ensure_chrome_container

    # 認証ファイルを共有ボリュームから /workspace/.claude/ にコピー
    mkdir -p "${PROJECT_DIR}/.claude"
    docker run --rm \
        --entrypoint bash \
        -v "${VOL_AUTH}:/auth:ro" \
        -v "${PROJECT_DIR}/.claude:/target" \
        "$IMG_CLAUDE" -c '
            for f in .credentials.json .claude.json; do
                [ -f "/auth/$f" ] && cp "/auth/$f" "/target/$f"
            done
            chown -R '"$(id -u):$(id -g)"' /target/
        '

    # .gitignore に .claude が含まれていなければ追加
    if [ -f "${PROJECT_DIR}/.gitignore" ]; then
        if ! grep -qxF '.claude' "${PROJECT_DIR}/.gitignore" && ! grep -qxF '.claude/' "${PROJECT_DIR}/.gitignore"; then
            echo '.claude' >> "${PROJECT_DIR}/.gitignore"
        fi
    elif [ -d "${PROJECT_DIR}/.git" ]; then
        echo '.claude' > "${PROJECT_DIR}/.gitignore"
    fi

    # Web アプリ用ポートマッピングを構築
    WEBAPP_BASE=$(find_available_webapp_port_block)
    WEBAPP_PORT_OPTS=""
    _i=0
    for cport in "${WEBAPP_DEV_PORTS[@]}"; do
        _hport=$((WEBAPP_BASE + _i))
        WEBAPP_PORT_OPTS="${WEBAPP_PORT_OPTS} -p ${_hport}:${cport}"
        _i=$((_i + 1))
    done

    # ~/.gitconfig があればマウント（読み取り専用）
    GITCONFIG_OPT=""
    if [ -f "${HOME}/.gitconfig" ]; then
        GITCONFIG_OPT="-v ${HOME}/.gitconfig:${CHOME}/.gitconfig:ro"
    fi

    # Docker ソケットマウント（ホストの Docker を利用）
    DOCKER_OPTS=""
    if [ -S /var/run/docker.sock ]; then
        DOCKER_OPTS="-v /var/run/docker.sock:/var/run/docker.sock"
    fi

    # SSH agent 準備 & ソケット転送（秘密鍵ファイルはマウントしない）
    ensure_ssh_agent
    SSH_OPTS=""
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
        SSH_OPTS="-v ${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:ro -e SSH_AUTH_SOCK=/tmp/ssh-agent.sock"
    fi
    # ~/.ssh/known_hosts（読み取り専用、秘密情報なし）
    if [ -f "${HOME}/.ssh/known_hosts" ]; then
        SSH_OPTS="${SSH_OPTS} -v ${HOME}/.ssh/known_hosts:${CHOME}/.ssh/known_hosts:ro"
    fi
    # ~/.ssh/config（エージェント転送用に加工してマウント）
    # IdentityFile / IdentitiesOnly はコンテナ内に鍵ファイルがないため除去
    if [ -f "${HOME}/.ssh/config" ]; then
        _ssh_config_tmp=$(mktemp /tmp/claude-dev-ssh-config.XXXXXX)
        sed -E '/^[[:space:]]*(IdentityFile|IdentitiesOnly)/d' "${HOME}/.ssh/config" > "$_ssh_config_tmp"
        SSH_OPTS="${SSH_OPTS} -v ${_ssh_config_tmp}:${CHOME}/.ssh/config:ro"
    fi

    # コンテナ起動
    echo "🚀 起動中... [${NAME}] → ${PROJECT_DIR}"
    docker run -d \
        --name "$NAME" \
        --hostname "$NAME" \
        --network "$NETWORK" \
        --cap-add NET_ADMIN \
        --cap-add NET_RAW \
        --restart unless-stopped \
        -v "${PROJECT_DIR}:/workspace" \
        -v "${VOL_HISTORY}:${CHOME}/.command_history" \
        -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
        -v "${VOL_CONFIG}:${CHOME}/.config-shared" \
        -v "${BASE_DIR}/scripts/tmux.conf:${CHOME}/.tmux.conf:ro" \
        -v "${BASE_DIR}/CLAUDE.md:${CHOME}/CLAUDE.md:ro" \
        $GITCONFIG_OPT \
        $SSH_OPTS \
        $DOCKER_OPTS \
        -e NODE_OPTIONS=--max-old-space-size=4096 \
        $WEBAPP_PORT_OPTS \
        -t \
        "$IMG_CLAUDE" >/dev/null

    # tmux 起動を待つ
    for i in $(seq 1 10); do
        if docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
            break
        fi
        sleep 0.5
    done

    echo "✅ 起動完了（Ctrl-_ D で切断、claude-dev start で再接続）"
    echo "📡 Port mappings (host → container):"
    show_port_mappings "$NAME"
    _url=$(get_chrome_novnc_url)
    [ -n "$_url" ] && echo "🖥️  noVNC: $_url"
    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# Claude Code を新しい tmux ウィンドウで起動
# -----------------------------------------------------------------------------
code)
    require_setup
    NAME=$(container_name)

    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません: claude-dev start を先に実行"
        exit 1
    fi

    docker exec -it -u "$CUSER" "$NAME" tmux new-window -t main "claude"
    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# 既存セッションに接続
# -----------------------------------------------------------------------------
attach)
    require_setup
    if [ -n "$2" ]; then
        # 名前指定
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        echo "   実行中のセッション: claude-dev list"
        exit 1
    fi

    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# プロジェクト停止
# -----------------------------------------------------------------------------
stop)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if container_exists "$NAME"; then
        docker rm -f "$NAME" >/dev/null
        echo "✅ ${NAME} を停止しました"
    else
        echo "ℹ️  ${NAME} は存在しません"
    fi

    # Claude コンテナが残っていなければ Chrome/VNC も停止
    stop_chrome_if_idle
    ;;

# -----------------------------------------------------------------------------
# ポートマッピング表示
# -----------------------------------------------------------------------------
ports)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        exit 1
    fi

    echo "📡 ${NAME} port mappings:"
    show_port_mappings "$NAME"

    _url=$(get_chrome_novnc_url)
    if [ -n "$_url" ]; then
        echo ""
        echo "🖥️  Chrome/VNC: $_url"
    fi
    ;;

# -----------------------------------------------------------------------------
# SSH フォワードコマンド生成
# -----------------------------------------------------------------------------
ssh-forward)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        exit 1
    fi

    _base=$(get_webapp_base_port "$NAME")
    if [ -z "$_base" ]; then
        echo "❌ ポートマッピングが見つかりません"
        exit 1
    fi

    echo "📋 SSH ControlMaster 設定（クライアント PC の ~/.ssh/config に追加を推奨）:"
    echo "  Host <server-name>"
    echo "      ControlMaster auto"
    echo "      ControlPath /tmp/ssh-%r@%h:%p"
    echo "      ControlPersist 10m"
    echo ""

    # 個別フォワードコマンド
    echo "📋 ポートフォワード追加コマンド（クライアント PC で実行）:"
    _i=0
    _forward_args=""
    for cport in "${WEBAPP_DEV_PORTS[@]}"; do
        _hport=$((_base + _i))
        echo "  ssh -O forward -L ${_hport}:localhost:${_hport} <server-name>   # → container:${cport} (${WEBAPP_DEV_LABELS[$_i]})"
        _forward_args="${_forward_args} -L ${_hport}:localhost:${_hport}"
        _i=$((_i + 1))
    done

    # Chrome/VNC の noVNC ポート
    novnc_port=$(docker port "$CHROME_CONTAINER" 6080 2>/dev/null | head -1 | sed 's/.*://')
    if [ -n "$novnc_port" ]; then
        echo "  ssh -O forward -L ${novnc_port}:localhost:${novnc_port} <server-name>   # → noVNC (Chrome)"
        _forward_args="${_forward_args} -L ${novnc_port}:localhost:${novnc_port}"
    fi

    echo ""
    echo "📋 一括転送（ControlMaster 未使用時）:"
    echo "  ssh${_forward_args} <server-name>"
    ;;

# -----------------------------------------------------------------------------
# 実行中セッション一覧
# -----------------------------------------------------------------------------
list)
    echo "=== 実行中の Claude Code セッション ==="
    _has_containers=0
    for cid in $(docker ps --filter "ancestor=$IMG_CLAUDE" -q 2>/dev/null); do
        _has_containers=1
        cname=$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')
        _name="${cname}"
        _status=$(docker inspect --format '{{.State.Status}}' "$cid")
        _workspace=$(docker inspect --format '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}' "$cid")
        _ports=""
        webapp_base=$(get_webapp_base_port "$cname")
        if [ -n "$webapp_base" ]; then
            _ports="Ports: ${webapp_base}-$((webapp_base + WEBAPP_PORTS_PER_CONTAINER - 1))"
        fi
        echo ""
        echo "  NAME:      ${_name}"
        echo "  STATUS:    ${_status}"
        echo "  WORKSPACE: ${_workspace}"
        [ -n "$_ports" ] && echo "  PORTS:     ${_ports}"
    done
    if [ $_has_containers -eq 0 ]; then
        echo "  (実行中のセッションはありません)"
    fi

    # Chrome/VNC コンテナの状態
    echo ""
    echo "=== Chrome/VNC コンテナ ==="
    if is_running "$CHROME_CONTAINER"; then
        _url=$(get_chrome_novnc_url)
        echo "  STATUS:  running"
        echo "  noVNC:   ${_url:-N/A}"
    else
        echo "  STATUS:  stopped（claude-dev start で自動起動）"
    fi

    ;;

# -----------------------------------------------------------------------------
# Claude Code アップグレード
# -----------------------------------------------------------------------------
upgrade)
    echo "📦 Claude Code を最新版に更新中..."
    docker build --no-cache -t "$IMG_CLAUDE" \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude イメージ更新完了"

    echo ""
    echo "📦 Chrome/VNC イメージを更新中..."
    docker build --no-cache -t "$IMG_CHROME" \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.chrome" "$BASE_DIR"
    echo "✅ Chrome/VNC イメージ更新完了"

    echo ""
    echo "   実行中のコンテナは stop → start で反映されます"
    ;;

# -----------------------------------------------------------------------------
# ファイアウォール確認
# -----------------------------------------------------------------------------
firewall)
    NAME=$(container_name)
    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません"
        exit 1
    fi
    docker exec "$NAME" iptables -L OUTPUT -n --line-numbers
    ;;

# -----------------------------------------------------------------------------
# 全リセット
# -----------------------------------------------------------------------------
reset)
    echo "⚠️  以下を全て削除します:"
    echo "   - 全 Claude Code コンテナ"
    echo "   - Chrome/VNC コンテナ"
    echo "   - 認証情報・履歴ボリューム"
    echo "   - Docker イメージ"
    echo ""
    read -p "実行しますか？ (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "キャンセルしました"
        exit 0
    fi

    # プロジェクトコンテナ停止
    docker ps -a --filter "ancestor=$IMG_CLAUDE" -q | xargs -r docker rm -f 2>/dev/null || true
    # Chrome/VNC コンテナ停止
    docker rm -f "$CHROME_CONTAINER" 2>/dev/null || true
    # ボリューム削除
    docker volume rm -f "$VOL_AUTH" "$VOL_HISTORY" "$VOL_CONFIG" "$VOL_CHROME" 2>/dev/null || true
    # ネットワーク削除
    docker network rm "$NETWORK" 2>/dev/null || true
    # イメージ削除
    docker rmi -f "$IMG_CLAUDE" "$IMG_CHROME" 2>/dev/null || true

    echo "✅ 全リセット完了"
    ;;

# -----------------------------------------------------------------------------
# ヘルプ
# -----------------------------------------------------------------------------
help|*)
    cat << 'EOF'
claude-dev - Claude Code 安全開発環境

セットアップ（初回のみ）:
  claude-dev setup               イメージビルド + インフラ構築
  claude-dev login               OAuth ログイン
  claude-dev logout              認証情報を削除

開発:
  claude-dev start               カレントディレクトリで環境を起動
                                 （Chrome/VNC コンテナも自動起動）
  claude-dev code                新しい tmux ウィンドウで Claude Code を起動
  claude-dev attach [NAME]       既存セッションに接続
  claude-dev stop [NAME]         セッションを停止
  claude-dev list                実行中セッション一覧

Web アプリアクセス:
  claude-dev ports [NAME]        ポートマッピング表示
  claude-dev ssh-forward [NAME]  SSH ポートフォワードコマンド生成

メンテナンス:
  claude-dev upgrade             Claude Code + Chrome を更新（イメージ再ビルド）
  claude-dev firewall            ファイアウォールルール確認
  claude-dev reset               全削除（コンテナ・ボリューム・イメージ）

使い方:
  cd ~/repos/my-project && claude-dev start

  Chrome/VNC は全プロジェクトで共有される専用コンテナで自動起動されます。
  noVNC URL は起動時に表示されます（http://localhost:6080/vnc.html?autoconnect=true）。
  日本語入力は Ctrl+\\ または F3 で切り替え（IBus-Mozc）。

[NAME] について:
  NAME はプロジェクトのディレクトリ名です。
  省略するとカレントディレクトリから自動判定します。
  claude-dev list で実行中セッションの NAME を確認できます。

Web アプリへのリモートアクセス:
  1. claude-dev start       → コンテナ起動（devポートは自動マッピング）
  2. claude-dev ports       → ホスト側ポート番号を確認
  3. クライアント PC で SSH ポートフォワード:
     ssh -O forward -L <host-port>:localhost:<host-port> <server>
  4. ブラウザで http://localhost:<host-port> にアクセス
  ※ claude-dev ssh-forward でコピペ用コマンドを生成できます
EOF
    ;;
esac
