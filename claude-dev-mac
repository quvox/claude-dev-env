#!/bin/bash
# =============================================================================
# claude-dev-mac - Claude Code 安全開発環境 CLI（macOS 版）
# =============================================================================
# macOS + Docker Desktop 上で、コンテナ隔離された Claude Code 環境を起動する。
# Linux 版 claude-dev の macOS 適応版。ホスト側 CLI の差分は SSH agent 転送・
# Docker ソケット検出・VM/KVM 非対応・ポートフォワード直結案内の 4 点。加えて
# Apple Silicon 向けにネイティブ arm64 で動かす（gcloud/Chrome のアーキ差分は共有イメージ側で
# 吸収）。設計: docs/09_macos-support.md §1-§5。
# コンテナ内資産のうち firewall / docker-proxy / tmux.conf は Linux 版と共有。Dockerfile /
# entrypoint は arm64 対応のアーキ別分岐を持つが amd64 では従来と同一（後方互換）。
# =============================================================================
set -e

# --- パス解決 ---
# `make install` は /usr/local/bin/claude-dev を本スクリプトへの symlink（sudo ln -sf）にする。
# readlink -f が symlink を解決するため BASE_DIR は repo を指す（repo 直実行時も同様）。
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0")"
BASE_DIR="$(dirname "$SCRIPT_PATH")"
CONFIG_FILE="${BASE_DIR}/.env"

# --- 設定読み込み ---
if [ -f "$CONFIG_FILE" ]; then
    set -a
    source "$CONFIG_FILE"
    set +a
fi

# --- Docker CLI の "What's next:" ヒントを抑制 ---
# docker run / exec 後（tmux から抜けた時など）に出るプロモ表示を止める。
# 利用者が明示設定していればそれを尊重する。
export DOCKER_CLI_HINTS="${DOCKER_CLI_HINTS:-false}"

# --- 定数 ---
NETWORK="claude-dev-net"
NOVNC_BASE_PORT=6080   # noVNC ポート開始番号
FWD_PORT_BASE=8100     # ポートフォワード用開始番号
VOL_AUTH="claude-dev-auth"
VOL_HISTORY="claude-dev-history"
VOL_CONFIG="claude-dev-config"
VOL_CHROME="claude-dev-chrome-data"
IMG_CLAUDE="claude-dev-claude"
IMG_CLAUDE_VNC="claude-dev-claude-vnc"
IMG_DOCKER_PROXY="claude-dev-docker-proxy"
DOCKER_PROXY_CONTAINER="claude-dev-docker-proxy"

# --- コンテナ内ユーザー名 ---
# 実行するイメージに焼き込まれた CONTAINER_USER を優先する（GHCR の generic user=dev 対応）。
# イメージが無ければホストの whoami にフォールバック（ローカルビルド運用は従来どおり＝後方互換）。
CUSER="$(docker image inspect "$IMG_CLAUDE" --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null | sed -n 's/^CONTAINER_USER=//p' | head -1)"
[ -n "$CUSER" ] || CUSER="$(whoami)"
CHOME="/home/${CUSER}"

# --- プラットフォーム ---
# ネイティブアーキでビルド/実行する（Apple Silicon = arm64 / Intel Mac = amd64）。
# 共有 Dockerfile はアーキ別に対応済み（arm64 は Playwright Chromium・gcloud は arm 写像。
# 設計 docs/09_macos-support.md §5）。エミュレーションは使わない。
# 利用者が DOCKER_DEFAULT_PLATFORM を明示している場合のみそれを尊重する。

# =============================================================================
# ヘルパー関数
# =============================================================================

# --- ユーザー設定ファイル / SSH（方式D: 専用 agent＋socat TCP ブリッジ）---
# 設計 docs/09_macos-support.md §1 / 実装仕様 docs/impl/11_cli-mac.md D1
USER_CONFIG="${HOME}/.config/claude-dev.yaml"
DEV_DIR="${HOME}/.claude-dev"
DEV_AGENT_SOCK="${DEV_DIR}/ssh-agent.sock"
DEV_AGENT_PID_FILE="${DEV_DIR}/ssh-agent.pid"
DEV_BRIDGE_PID_FILE="${DEV_DIR}/ssh-bridge.pid"
DEV_BRIDGE_PORT_FILE="${DEV_DIR}/ssh-bridge.port"

# ~/.ssh/id_*（.pub 除く）を DISCOVERED_KEYS に列挙
discover_ssh_keys() {
    DISCOVERED_KEYS=()
    local f
    for f in "$HOME"/.ssh/id_*; do
        case "$f" in *.pub) continue ;; esac
        [ -f "$f" ] && DISCOVERED_KEYS+=("$f")
    done
}

# config に ssh_keys セクションがあるか（=選択済み）
config_has_ssh_selection() {
    [ -f "$USER_CONFIG" ] && grep -qE '^ssh_keys:' "$USER_CONFIG"
}

# config の ssh_keys を SSH_KEY_LIST に読み込む（自動生成はしない）
load_config_ssh_keys() {
    SSH_KEY_LIST=()
    [ -f "$USER_CONFIG" ] || return 0
    local line val in_section=0
    while IFS= read -r line; do
        case "$line" in \#*|"") continue ;; esac
        if [[ "$line" =~ ^ssh_keys: ]]; then in_section=1; continue; fi
        if [[ $in_section -eq 1 && "$line" =~ ^[a-zA-Z_] ]]; then break; fi
        if [[ $in_section -eq 1 && "$line" =~ ^[[:space:]]*-[[:space:]]+(.*) ]]; then
            val="${BASH_REMATCH[1]}"; val="${val%%#*}"
            val="$(echo "$val" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            val="${val/#\~/$HOME}"
            [ -n "$val" ] && SSH_KEY_LIST+=("$val")
        fi
    done < "$USER_CONFIG"
}

# 選択鍵を config に書き出す（引数=鍵パス群。claude-dev が所有するファイル）
write_config_ssh_keys() {
    mkdir -p "$(dirname "$USER_CONFIG")"
    {
        echo "# claude-dev 設定ファイル（このファイルは claude-dev が管理します）"
        echo "# ssh_keys: コンテナへ転送する SSH 鍵。再選択は 'claude-dev ssh-keys'、初期化は 'claude-dev ssh-keys reset'"
        echo "ssh_keys:"
        local k
        for k in "$@"; do echo "  - $k"; done
    } > "$USER_CONFIG"
}

# ~/.ssh の鍵を対話選択し config に保存。結果を SSH_KEY_LIST にも反映
select_ssh_keys_interactive() {
    discover_ssh_keys
    if [ ${#DISCOVERED_KEYS[@]} -eq 0 ]; then
        echo "⚠️  ~/.ssh に鍵ファイル（id_*）が見つかりません。SSH 転送なしで続行します。"
        write_config_ssh_keys
        SSH_KEY_LIST=()
        return 0
    fi
    echo "利用可能な SSH 鍵:"
    local i=1 k
    for k in "${DISCOVERED_KEYS[@]}"; do echo "  $i) $k"; i=$((i + 1)); done
    printf "コンテナで使う鍵を選択 (番号をカンマ/空白区切り, a=全部, n=なし): "
    local ans=""; read -r ans || ans=""
    local chosen=() tok
    case "$ans" in
        a|A|all|ALL) chosen=("${DISCOVERED_KEYS[@]}") ;;
        n|N|none|NONE|"") chosen=() ;;
        *)
            for tok in $(echo "$ans" | tr ',' ' '); do
                case "$tok" in ''|*[!0-9]*) continue ;; esac
                if [ "$tok" -ge 1 ] && [ "$tok" -le ${#DISCOVERED_KEYS[@]} ]; then
                    chosen+=("${DISCOVERED_KEYS[$((tok - 1))]}")
                fi
            done
            ;;
    esac
    write_config_ssh_keys "${chosen[@]}"
    echo "✅ SSH 鍵の選択を保存しました: $USER_CONFIG（${#chosen[@]} 件）"
    SSH_KEY_LIST=("${chosen[@]}")
}

# 専用 ssh-agent（~/.claude-dev/ssh-agent.sock）を起動し、選択鍵を ssh-add する
# SSH_KEY_LIST を事前に用意しておくこと。成功で 0。
ensure_dedicated_agent() {
    mkdir -p "$DEV_DIR"
    local rc=0
    SSH_AUTH_SOCK="$DEV_AGENT_SOCK" ssh-add -l >/dev/null 2>&1 || rc=$?
    if [ "$rc" -eq 2 ] || [ ! -S "$DEV_AGENT_SOCK" ]; then
        rm -f "$DEV_AGENT_SOCK"
        local out
        out=$(ssh-agent -a "$DEV_AGENT_SOCK" 2>/dev/null) || {
            echo "⚠️  専用 ssh-agent の起動に失敗しました"; return 1; }
        echo "$out" | sed -n 's/.*SSH_AGENT_PID=\([0-9][0-9]*\).*/\1/p' | head -1 > "$DEV_AGENT_PID_FILE"
    fi
    # 選択鍵を追加（重複 add は無害。パスフレーズ付きは対話で一度だけ）
    local key need_pp=()
    for key in "${SSH_KEY_LIST[@]}"; do
        [ -f "$key" ] || { echo "⚠️  ${key}: 見つかりません（スキップ）"; continue; }
        if SSH_AUTH_SOCK="$DEV_AGENT_SOCK" SSH_ASKPASS=/bin/false SSH_ASKPASS_REQUIRE=force ssh-add "$key" 2>/dev/null; then
            :
        else
            need_pp+=("$key")
        fi
    done
    if [ ${#need_pp[@]} -gt 0 ]; then
        echo "🔑 パスフレーズ付きの鍵を専用 agent に追加します（初回のみ入力）:"
        for key in "${need_pp[@]}"; do
            SSH_AUTH_SOCK="$DEV_AGENT_SOCK" ssh-add "$key" || echo "⚠️  ${key}: 追加できませんでした（スキップ）"
        done
    fi
    return 0
}

# 空き 127.0.0.1 TCP ポートを返す（9700〜。forward(8100〜)/noVNC(6080〜) と重ならない範囲）
find_free_local_port() {
    local p
    for p in $(seq 9700 9799); do
        if ! (: </dev/tcp/127.0.0.1/"$p") 2>/dev/null; then echo "$p"; return 0; fi
    done
    echo 9700
}

# 専用 agent への host socat ブリッジを起動し、使用中ポートを標準出力に返す
# socat が無い/起動失敗なら非0を返す（呼び出し側は SSH 転送をスキップ）
ensure_ssh_bridge() {
    if ! command -v socat >/dev/null 2>&1; then
        echo "⚠️  socat が見つかりません。SSH agent 転送には socat が必要です。" >&2
        echo "    👉 導入してください:  brew install socat" >&2
        echo "    （導入後に 'claude-dev start' を再実行してください。今回は SSH agent 転送なしで続行します）" >&2
        return 1
    fi
    mkdir -p "$DEV_DIR"
    # 既存ブリッジが生きていればその port を再利用
    if [ -f "$DEV_BRIDGE_PID_FILE" ] && [ -f "$DEV_BRIDGE_PORT_FILE" ] \
       && kill -0 "$(cat "$DEV_BRIDGE_PID_FILE" 2>/dev/null)" 2>/dev/null; then
        cat "$DEV_BRIDGE_PORT_FILE"
        return 0
    fi
    local port="${CLAUDE_DEV_SSH_BRIDGE_PORT:-}"
    [ -n "$port" ] || port=$(find_free_local_port)
    nohup socat "TCP-LISTEN:${port},bind=127.0.0.1,fork,reuseaddr" "UNIX-CONNECT:${DEV_AGENT_SOCK}" >/dev/null 2>&1 &
    echo $! > "$DEV_BRIDGE_PID_FILE"
    echo "$port" > "$DEV_BRIDGE_PORT_FILE"
    echo "$port"
}

# 稼働中 claude コンテナが 0 ならブリッジ socat を停止（専用 agent は残す）
stop_ssh_bridge_if_idle() {
    local count
    count=$(docker ps --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q 2>/dev/null | wc -l)
    if [ "$count" -eq 0 ] && [ -f "$DEV_BRIDGE_PID_FILE" ]; then
        kill "$(cat "$DEV_BRIDGE_PID_FILE" 2>/dev/null)" 2>/dev/null || true
        rm -f "$DEV_BRIDGE_PID_FILE" "$DEV_BRIDGE_PORT_FILE"
        echo "🔌 SSH ブリッジを停止しました（Claude コンテナなし）"
    fi
}

# プロジェクト名（カレントディレクトリから導出）
project_name() {
    basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g'
}

# コンテナ名（= ディレクトリ名）
container_name() {
    project_name
}

# Docker ソケットのパスを検出（macOS/Docker Desktop 対応）
# /var/run/docker.sock（既定ソケット有効時のシンボリックリンク）を優先し、
# 無ければ Docker Desktop の既定ソケット ~/.docker/run/docker.sock を探す。
# 見つかったパスを標準出力へ返す（無ければ空文字）。
detect_docker_sock() {
    if [ -S /var/run/docker.sock ]; then
        echo "/var/run/docker.sock"
    elif [ -S "${HOME}/.docker/run/docker.sock" ]; then
        echo "${HOME}/.docker/run/docker.sock"
    fi
}

# イメージが存在するか
image_exists() {
    docker image inspect "$1" >/dev/null 2>&1
}

# コンテナが実行中か
is_running() {
    docker ps -q -f "name=^${1}$" 2>/dev/null | grep -q .
}

# コンテナが存在するか（停止含む）
container_exists() {
    docker ps -aq -f "name=^${1}$" 2>/dev/null | grep -q .
}

# 使用可能な noVNC ポートを探す
find_available_novnc_port() {
    local port=$NOVNC_BASE_PORT
    while [ $port -lt $((NOVNC_BASE_PORT + 100)) ]; do
        if ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${port}->"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
    done
    echo "$NOVNC_BASE_PORT"
}

# 使用可能なホストポートを探す
find_available_host_port() {
    local port=$FWD_PORT_BASE
    local max=$((FWD_PORT_BASE + 900))
    while [ $port -lt $max ]; do
        if ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${port}->"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
    done
    echo "$FWD_PORT_BASE"
}

# セットアップ済みか確認（イメージがなければ自動ビルド）
require_setup() {
    if ! image_exists "$IMG_CLAUDE"; then
        echo "📦 Claude ベースイメージが見つかりません。ビルドします..."
        docker build -t "$IMG_CLAUDE" \
            --target base \
            --build-arg USERNAME="$CUSER" \
            --build-arg USER_UID="$(id -u)" \
            --build-arg USER_GID="$(id -g)" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    fi
    if ! image_exists "$IMG_CLAUDE_VNC"; then
        echo "📦 Claude VNC イメージが見つかりません。ビルドします..."
        docker build -t "$IMG_CLAUDE_VNC" \
            --target vnc \
            --build-arg USERNAME="$CUSER" \
            --build-arg USER_UID="$(id -u)" \
            --build-arg USER_GID="$(id -g)" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    fi
}

# Docker リソースの準備
ensure_infrastructure() {
    docker network create "$NETWORK" 2>/dev/null || true
    docker volume create "$VOL_AUTH" >/dev/null 2>&1 || true
    docker volume create "$VOL_HISTORY" >/dev/null 2>&1 || true
    docker volume create "$VOL_CONFIG" >/dev/null 2>&1 || true
    docker volume create "$VOL_CHROME" >/dev/null 2>&1 || true  # Chrome プロファイル
}

# 指定コンテナの noVNC URL を取得
get_novnc_url() {
    local port
    port=$(docker port "$1" 6080 2>/dev/null | head -1 | sed 's/.*://')
    if [ -n "$port" ]; then
        echo "http://localhost:${port}/vnc.html?autoconnect=true"
    fi
}

# 指定イメージ（または image ID）のバージョン表記を返す
# org.opencontainers.image.version ラベル優先（CI=YYYYMMDDHHmm / ローカル=local）、
# 無ければ unknown。あわせて短縮 ID と作成日時を付す。
image_version() {
    local ref="$1" v id created
    v=$(docker image inspect "$ref" --format '{{index .Config.Labels "io.github.quvox.claude-dev.version"}}' 2>/dev/null)
    id=$(docker image inspect "$ref" --format '{{.Id}}' 2>/dev/null | sed 's/^sha256://' | cut -c1-12)
    created=$(docker image inspect "$ref" --format '{{.Created}}' 2>/dev/null | cut -c1-16 | tr 'T' ' ')
    case "$v" in ""|"<no value>") v="unknown" ;; esac
    echo "${v} (id ${id}, built ${created})"
}

# Claude コンテナが 0 なら Docker Proxy コンテナを停止
stop_proxy_if_idle() {
    local count
    count=$(docker ps --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q 2>/dev/null | wc -l)
    if [ "$count" -eq 0 ]; then
        if is_running "$DOCKER_PROXY_CONTAINER"; then
            docker rm -f "$DOCKER_PROXY_CONTAINER" >/dev/null
            echo "🐳 Docker Socket Proxy コンテナを停止しました（Claude コンテナなし）"
        fi
    fi
}

# Docker Socket Proxy 共有コンテナを起動（未起動の場合のみ）
ensure_docker_proxy_container() {
    # Docker ソケットがなければスキップ
    local sock
    sock=$(detect_docker_sock)
    if [ -z "$sock" ]; then
        return 0
    fi

    # イメージがなければビルド
    if ! image_exists "$IMG_DOCKER_PROXY"; then
        echo "📦 Docker Socket Proxy イメージが見つかりません。ビルドします..."
        docker build -t "$IMG_DOCKER_PROXY" \
            -f "${BASE_DIR}/.devcontainer/Dockerfile.docker-proxy" "$BASE_DIR"
    fi

    # 既に実行中なら何もしない
    if is_running "$DOCKER_PROXY_CONTAINER"; then
        return 0
    fi

    # 停止中のコンテナがあれば削除
    if container_exists "$DOCKER_PROXY_CONTAINER"; then
        docker rm -f "$DOCKER_PROXY_CONTAINER" >/dev/null
    fi

    # /workspace 配下 bind の許可（既定有効・docs/03 §5 / docs/impl/50）。
    # 無効化は host 環境で CLAUDE_DEV_ALLOW_WORKSPACE_BINDS=0 を設定し proxy を作り直す。
    docker run -d \
        --name "$DOCKER_PROXY_CONTAINER" \
        --hostname "$DOCKER_PROXY_CONTAINER" \
        --network "$NETWORK" \
        --restart unless-stopped \
        -e "CLAUDE_DEV_ALLOW_WORKSPACE_BINDS=${CLAUDE_DEV_ALLOW_WORKSPACE_BINDS:-1}" \
        -v "${sock}:/var/run/docker.sock:ro" \
        "$IMG_DOCKER_PROXY" >/dev/null

    echo "🐳 Docker Socket Proxy コンテナ起動"
}

# =============================================================================
# コマンド
# =============================================================================
case "${1:-help}" in

# -----------------------------------------------------------------------------
# 初回セットアップ
# -----------------------------------------------------------------------------
setup)
    echo "🚀 Claude Code 開発環境セットアップ（macOS）"
    echo ""

    # .env
    if [ ! -f "${BASE_DIR}/.env" ]; then
        cp "${BASE_DIR}/.env.example" "${BASE_DIR}/.env"
        echo "✅ .env を作成しました（必要に応じて ${BASE_DIR}/.env を編集）"
    else
        echo "ℹ️  .env は既に存在します"
    fi

    # ネットワーク
    docker network create "$NETWORK" 2>/dev/null || true
    echo "✅ ネットワーク: $NETWORK"

    # ボリューム
    docker volume create "$VOL_AUTH" >/dev/null 2>&1 || true
    docker volume create "$VOL_HISTORY" >/dev/null 2>&1 || true
    docker volume create "$VOL_CONFIG" >/dev/null 2>&1 || true
    docker volume create "$VOL_CHROME" >/dev/null 2>&1 || true
    echo "✅ ボリューム: $VOL_AUTH, $VOL_HISTORY, $VOL_CONFIG, $VOL_CHROME"

    # Claude ベースイメージビルド
    echo ""
    echo "📦 Claude ベースイメージをビルド中... (user: $CUSER)"
    docker build -t "$IMG_CLAUDE" \
        --target base \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude ベースイメージビルド完了"

    # Claude VNC イメージビルド
    echo ""
    echo "📦 Claude VNC イメージをビルド中..."
    docker build -t "$IMG_CLAUDE_VNC" \
        --target vnc \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude VNC イメージビルド完了"

    # Docker Socket Proxy イメージビルド
    echo ""
    echo "📦 Docker Socket Proxy イメージをビルド中..."
    docker build -t "$IMG_DOCKER_PROXY" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.docker-proxy" "$BASE_DIR"
    echo "✅ Docker Socket Proxy イメージビルド完了"

    echo ""
    echo "============================================"
    echo "✅ セットアップ完了！"
    echo ""
    echo "次のステップ:"
    echo "  1. claude-dev login"
    echo "  2. cd /path/to/your/project"
    echo "  3. claude-dev start"
    echo ""
    if ! command -v claude-dev >/dev/null 2>&1; then
        echo "PATH に追加:"
        echo "  make install   # OS を判定し claude-dev-mac を /usr/local/bin/claude-dev へ symlink（sudo）"
        echo "  # 手動の場合: sudo ln -sf ${BASE_DIR}/claude-dev-mac /usr/local/bin/claude-dev"
    fi
    echo "============================================"
    ;;

# -----------------------------------------------------------------------------
# OAuth ログイン
# -----------------------------------------------------------------------------
login)
    require_setup
    ensure_infrastructure
    echo "📋 Claude OAuth ログイン"
    echo ""
    echo "Claude Code が起動します。ログインを完了してから /exit で終了してください。"
    echo ""

    # claude-dev-auth ボリュームを ~/.claude-shared にマウント
    # 認証ファイル（.credentials.json, .claude.json）だけを共有ボリュームに永続化
    # settings.json は共有しない（コンテナごとに独立管理）
    docker run --rm -it \
        --network "$NETWORK" \
        --entrypoint bash \
        -e "TERM=${TERM:-xterm-256color}" \
        -e "LANG=en_US.UTF-8" \
        -e "CUSER=$CUSER" \
        -e "CHOME=$CHOME" \
        -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
        "$IMG_CLAUDE" \
        -c '
            chown -R "$CUSER":"$CUSER" "$CHOME/.claude-shared" 2>/dev/null || true
            mkdir -p "$CHOME/.claude"
            chown "$CUSER":"$CUSER" "$CHOME/.claude"

            # settings.json はローカルに作成（共有しない）
            # この -c スクリプト全体がホスト側でシングルクォートに括られているため、
            # 内部でシングルクォートを使うと外側の引用が閉じて JSON が壊れる（ブレース展開）
            if [ ! -f "$CHOME/.claude/settings.json" ]; then
                echo "{\"permissions\":{\"defaultMode\":\"bypassPermissions\"},\"model\":\"sonnet\"}" > "$CHOME/.claude/settings.json"
                chown "$CUSER":"$CUSER" "$CHOME/.claude/settings.json"
            fi

            su "$CUSER" -s /bin/bash -l -c "
                # 共有ボリュームに認証情報があれば ~/.claude/ にコピー
                for f in .credentials.json .claude.json; do
                    if [ -f ~/.claude-shared/\$f ]; then
                        cp ~/.claude-shared/\$f ~/.claude/\$f
                    fi
                done
                # ~/.claude.json（ホーム直下）へのリンク
                if [ -f ~/.claude/.claude.json ]; then
                    ln -sf ~/.claude/.claude.json ~/.claude.json
                fi

                claude || true

                # login 後: 認証ファイルを共有ボリュームに永続化
                for f in .credentials.json .claude.json; do
                    src=~/.claude/\$f
                    dst=~/.claude-shared/\$f
                    if [ -f \"\$src\" ]; then
                        cp \"\$src\" \"\$dst\"
                    fi
                done
                # ホーム直下の .claude.json も確認
                if [ -f ~/.claude.json ] && [ ! -L ~/.claude.json ]; then
                    cp ~/.claude.json ~/.claude-shared/.claude.json
                fi
            "
        '

    echo "✅ ログイン処理完了"
    ;;

# -----------------------------------------------------------------------------
# ログイン情報削除
# -----------------------------------------------------------------------------
logout)
    require_setup
    echo "🗑️  認証情報を削除中..."
    # auth ボリューム（= ~/.claude-shared/）をクリア
    # 実行中のコンテナがあるとボリュームが使用中なので先に停止
    echo "   実行中のコンテナを停止中..."
    docker ps -a --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q | xargs -r docker rm -f 2>/dev/null || true
    # Docker Socket Proxy コンテナも停止
    if container_exists "$DOCKER_PROXY_CONTAINER"; then
        docker rm -f "$DOCKER_PROXY_CONTAINER" >/dev/null 2>&1 || true
    fi
    # ボリュームを空にする
    docker run --rm --entrypoint bash \
        -v "${VOL_AUTH}:/auth" \
        "$IMG_CLAUDE" \
        -c "rm -rf /auth/* /auth/.*" 2>/dev/null || true
    echo "✅ 認証情報を削除しました"
    echo "   再ログイン: claude-dev login"
    ;;

# -----------------------------------------------------------------------------
# GHCR からイメージを取得してローカル名に retag（ビルドの代わりに使う）
#   claude-dev pull [TAG]
#   .env の CLAUDE_DEV_REGISTRY（既定 ghcr.io/quvox）/ CLAUDE_DEV_IMAGE_TAG（既定 latest）を参照。
#   引数 TAG で latest 以外（YYYYMMDDHHmm）に固定できる。
# -----------------------------------------------------------------------------
pull)
    REG="${CLAUDE_DEV_REGISTRY:-ghcr.io/quvox}"
    TAG="${2:-${CLAUDE_DEV_IMAGE_TAG:-latest}}"
    echo "📥 GHCR からイメージを取得します: ${REG}/{$IMG_CLAUDE,$IMG_CLAUDE_VNC,$IMG_DOCKER_PROXY}:${TAG}"
    _pull_ok=0
    for name in "$IMG_CLAUDE" "$IMG_CLAUDE_VNC" "$IMG_DOCKER_PROXY"; do
        src="${REG}/${name}:${TAG}"
        echo "  - pull ${src}"
        if docker pull "$src"; then
            docker tag "$src" "${name}:latest"
            echo "    → ローカル名 ${name} に retag"
            _pull_ok=1
        else
            echo "    ⚠️  ${src} の取得に失敗（存在しない/未ログイン/権限？）"
        fi
    done
    if [ "$_pull_ok" = "1" ]; then
        echo "✅ pull 完了。'claude-dev start' はこのイメージを使います（再ビルドしません）"
        echo "   固定バージョンは 'claude-dev pull <YYYYMMDDHHmm>' か .env の CLAUDE_DEV_IMAGE_TAG"
    else
        echo "❌ すべての pull に失敗しました。private リポジトリなら 'docker login ghcr.io' が必要です"
        exit 1
    fi
    ;;

# -----------------------------------------------------------------------------
# プロジェクト開始（カレントディレクトリ）
# -----------------------------------------------------------------------------
start)
    NAME=$(container_name)
    PROJECT_DIR="$(pwd)"
    shift || true

    # フラグ解析（VM/KVM は macOS 非対応。イメージビルド前に早期拒否する）
    USE_VNC=1
    while [ $# -gt 0 ]; do
        case "$1" in
            --no-vnc) USE_VNC=0 ;;
            --kvm|--vm|--vm-fresh)
                echo "❌ $1 は macOS では利用できません。"
                echo "   macOS/Docker Desktop には /dev/kvm がなく、ネスト仮想化も使えないため VM/KVM モードは非対応です。"
                echo "   Docker を多用する開発は通常起動（Docker Socket Proxy 経由）で行ってください。"
                exit 1
                ;;
        esac
        shift
    done

    require_setup

    # 既に実行中 → attach（tmux セッションがなければ再作成）
    if is_running "$NAME"; then
        echo "✅ ${NAME} は実行中。接続します..."
        _img_id=$(docker inspect --format '{{.Image}}' "$NAME" 2>/dev/null)
        [ -n "$_img_id" ] && echo "🏷️  イメージバージョン: $(image_version "$_img_id")"
        ensure_infrastructure
        _url=$(get_novnc_url "$NAME")
        [ -n "$_url" ] && echo "🖥️  noVNC: $_url"
        if ! docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
            docker exec -u "$CUSER" "$NAME" tmux new-session -d -s main 2>/dev/null || true
            sleep 0.5
        fi
        docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
        exit 0
    fi

    # 停止中のコンテナがあれば削除
    if container_exists "$NAME"; then
        docker rm -f "$NAME" >/dev/null
    fi

    # インフラ確認
    ensure_infrastructure

    # イメージ選択
    if [ "$USE_VNC" = "1" ]; then
        RUN_IMAGE="$IMG_CLAUDE_VNC"
    else
        RUN_IMAGE="$IMG_CLAUDE"
    fi

    # 認証ファイルを共有ボリュームから /workspace/.claude/ にコピー
    mkdir -p "${PROJECT_DIR}/.claude"
    docker run --rm \
        --entrypoint bash \
        -v "${VOL_AUTH}:/auth:ro" \
        -v "${PROJECT_DIR}/.claude:/target" \
        "$IMG_CLAUDE" -c '
            for f in .credentials.json .claude.json; do
                [ -f "/auth/$f" ] && cp "/auth/$f" "/target/$f"
            done
            chown -R '"$(id -u):$(id -g)"' /target/
        '

    # ホストの ~/.claude/settings.json から hooks / env 設定を抽出してコピー
    # （ファイル名は歴史的経緯で host-hooks.json のままだが env も含む）
    HOST_SETTINGS="${HOME}/.claude/settings.json"
    if [ -f "$HOST_SETTINGS" ]; then
        _overlay=$(jq -c '{hooks: .hooks, env: .env} | with_entries(select(.value != null))' "$HOST_SETTINGS" 2>/dev/null)
        if [ -n "$_overlay" ] && [ "$_overlay" != "{}" ]; then
            echo "$_overlay" > "${PROJECT_DIR}/.claude/host-hooks.json"
        fi
    fi

    # ホストの ~/.local/bin/ スクリプト（ユーザー独自 hook 用）をコンテナ用にコピー
    # 組み込み hook スクリプト (save_prompt.sh / sendslackmsg.sh) はイメージに焼き込み済みのため
    # ここではコピー対象外。ユーザー独自スクリプトのみ ~/.local/bin/ から運ぶ。
    if [ -d "${HOME}/.local/bin" ] && [ -n "$(ls -A "${HOME}/.local/bin/" 2>/dev/null)" ]; then
        mkdir -p "${PROJECT_DIR}/.claude/host-local-bin"
        cp -a "${HOME}/.local/bin/." "${PROJECT_DIR}/.claude/host-local-bin/"
    fi

    # .gitignore に .claude が含まれていなければ追加
    if [ -f "${PROJECT_DIR}/.gitignore" ]; then
        if ! grep -qxF '.claude' "${PROJECT_DIR}/.gitignore" && ! grep -qxF '.claude/' "${PROJECT_DIR}/.gitignore"; then
            echo '.claude' >> "${PROJECT_DIR}/.gitignore"
        fi
    elif [ -d "${PROJECT_DIR}/.git" ]; then
        echo '.claude' > "${PROJECT_DIR}/.gitignore"
    fi

    # ~/.gitconfig があればマウント（読み取り専用）
    GITCONFIG_OPT=""
    if [ -f "${HOME}/.gitconfig" ]; then
        GITCONFIG_OPT="-v ${HOME}/.gitconfig:${CHOME}/.gitconfig:ro"
    fi

    # Docker Socket Proxy 経由で Docker API を利用（生ソケットはマウントしない）
    # macOS/Docker Desktop のソケットは /var/run/docker.sock または ~/.docker/run/docker.sock
    DOCKER_OPTS=""
    if [ -n "$(detect_docker_sock)" ]; then
        ensure_docker_proxy_container
        DOCKER_OPTS="-e DOCKER_HOST=tcp://${DOCKER_PROXY_CONTAINER}:2375"
    fi

    # SSH agent（方式D: claude-dev 専用 agent＋socat TCP ブリッジ。秘密鍵はコンテナに渡さない）
    # macOS の Unix ソケットはコンテナへ直接マウントできず、Docker Desktop 魔法ソケットは
    # 利用者の鍵がある agent を転送しないため、専用 agent を鍵ファイルから構築して転送する。
    SSH_OPTS=""
    # 鍵の選択（未選択なら対話選択して config 保存。以後は config を使う）
    if config_has_ssh_selection; then
        load_config_ssh_keys
    else
        select_ssh_keys_interactive
    fi
    _valid_keys=0
    for _k in "${SSH_KEY_LIST[@]}"; do [ -f "$_k" ] && _valid_keys=1; done
    if [ "$_valid_keys" = "1" ]; then
        if ensure_dedicated_agent; then
            _sshport=$(ensure_ssh_bridge) || _sshport=""
            if [ -n "$_sshport" ]; then
                SSH_OPTS="-e CLAUDE_DEV_SSH_BRIDGE_PORT=${_sshport}"
                echo "🔑 SSH agent 転送: 127.0.0.1:${_sshport}（専用 agent、選択鍵 ${#SSH_KEY_LIST[@]} 件）"
            fi
        fi
    else
        echo "ℹ️  SSH 鍵が未選択のため SSH agent 転送なしで起動します（'claude-dev ssh-keys' で選択）"
    fi
    # ~/.ssh/known_hosts（読み取り専用、秘密情報なし）
    if [ -f "${HOME}/.ssh/known_hosts" ]; then
        SSH_OPTS="${SSH_OPTS} -v ${HOME}/.ssh/known_hosts:${CHOME}/.ssh/known_hosts:ro"
    fi
    # ~/.ssh/config（エージェント転送用に加工した「一時コピー」を RO マウント。ホストの config は不変）
    # IdentityFile / IdentitiesOnly はコンテナ内に鍵ファイルがないため除去。
    # IdentityAgent はホスト固有の agent パス（例 Strongbox の ~/.strongbox/agent.sock）を指し、
    # コンテナ内では存在せず SSH_AUTH_SOCK（= /tmp/ssh-agent.sock のブリッジ）を上書きして
    # agent を不通にするため必ず除去する。
    if [ -f "${HOME}/.ssh/config" ]; then
        _ssh_config_tmp=$(mktemp /tmp/claude-dev-ssh-config.XXXXXX)
        sed -E '/^[[:space:]]*(IdentityFile|IdentitiesOnly|IdentityAgent)/d' "${HOME}/.ssh/config" > "$_ssh_config_tmp"
        SSH_OPTS="${SSH_OPTS} -v ${_ssh_config_tmp}:${CHOME}/.ssh/config:ro"
    fi

    # noVNC ポート割り当て（VNC ありの場合のみ）
    NOVNC_PORT_OPT=""
    if [ "$USE_VNC" = "1" ]; then
        NOVNC_PORT=$(find_available_novnc_port)
        NOVNC_PORT_OPT="-p ${NOVNC_PORT}:6080 -v ${VOL_CHROME}:${CHOME}/.chrome-profile"
    fi

    # コンテナ起動
    echo "🚀 起動中... [${NAME}] → ${PROJECT_DIR}"
    echo "🏷️  イメージ: ${RUN_IMAGE}  バージョン $(image_version "$RUN_IMAGE")"
    docker run -d \
        --name "$NAME" \
        --hostname "$NAME" \
        --network "$NETWORK" \
        --cap-add NET_ADMIN \
        --cap-add NET_RAW \
        --restart unless-stopped \
        -v "${PROJECT_DIR}:/workspace" \
        -v "${VOL_HISTORY}:${CHOME}/.command_history" \
        -v "${VOL_AUTH}:${CHOME}/.claude-shared" \
        -v "${VOL_CONFIG}:${CHOME}/.config-shared" \
        -v "${BASE_DIR}/scripts/tmux.conf:${CHOME}/.tmux.conf:ro" \
        -v "${BASE_DIR}/CLAUDE.md:${CHOME}/CLAUDE.md:ro" \
        $GITCONFIG_OPT \
        $SSH_OPTS \
        $DOCKER_OPTS \
        $NOVNC_PORT_OPT \
        -e NODE_OPTIONS=--max-old-space-size=4096 \
        -t \
        "$RUN_IMAGE" >/dev/null

    # tmux 起動を待つ
    for i in $(seq 1 30); do
        if docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
            break
        fi
        sleep 1
    done

    # tmux がまだ上がっていなければ、無言で attach 失敗して終了せず状況を案内する
    if ! docker exec -u "$CUSER" "$NAME" tmux has-session -t main 2>/dev/null; then
        echo "⏳ tmux セッションの起動待ちがタイムアウトしました。'claude-dev start' を再実行してください。"
        exit 0
    fi

    echo "✅ 起動完了（Ctrl-_ D で切断、claude-dev start で再接続）"
    _url=$(get_novnc_url "$NAME")
    [ -n "$_url" ] && echo "🖥️  noVNC: $_url"
    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# Claude Code を新しい tmux ウィンドウで起動
# -----------------------------------------------------------------------------
code)
    require_setup
    NAME=$(container_name)

    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません: claude-dev start を先に実行"
        exit 1
    fi

    docker exec -it -u "$CUSER" "$NAME" tmux new-window -t main "claude"
    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# AI オーケストレーターを新しい tmux ウィンドウで起動
#   claude-dev orchestrate [<ゴール>] [--fresh]
#   ゴールは任意（既定は壁打ちから開始）。
#   --fresh で前回の実行状態（state/plan/control・worktree/orch ブランチ）を
#   破棄して壁打ちから新規開始する（中断した executing/intervening の再開を上書き）。
#   worker の実行内容はダッシュボードの [d] キーでライブ表示できる。
# -----------------------------------------------------------------------------
orchestrate)
    require_setup
    NAME=$(container_name)

    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません: claude-dev start を先に実行"
        exit 1
    fi

    shift  # "orchestrate" を除去
    _fresh=""
    _goal=""
    for a in "$@"; do
        case "$a" in
            --fresh) _fresh="--fresh" ;;
            *) if [ -z "$_goal" ]; then _goal="$a"; else _goal="$_goal $a"; fi ;;
        esac
    done

    # コンテナ内コマンドを組み立てる（workspace は /workspace 固定）
    _cmd="claude-orchestrator --workspace /workspace"
    [ -n "$_fresh" ] && _cmd="$_cmd $_fresh"
    if [ -n "$_goal" ]; then
        _esc=$(printf '%s' "$_goal" | sed 's/"/\\"/g')
        _cmd="$_cmd \"$_esc\""
    fi

    docker exec -it -u "$CUSER" "$NAME" tmux new-window -t main -c /workspace "$_cmd"
    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# 既存セッションに接続
# -----------------------------------------------------------------------------
attach)
    require_setup
    if [ -n "$2" ]; then
        # 名前指定
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        echo "   実行中のセッション: claude-dev list"
        exit 1
    fi

    docker exec -it -u "$CUSER" "$NAME" tmux attach -t main
    ;;

# -----------------------------------------------------------------------------
# プロジェクト停止
# -----------------------------------------------------------------------------
stop)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if container_exists "$NAME"; then
        # フォワードコンテナも停止
        docker ps -a --filter "name=^fwd-${NAME}-" -q | xargs -r docker rm -f 2>/dev/null || true
        docker rm -f "$NAME" >/dev/null
        echo "✅ ${NAME} を停止しました"
    else
        echo "ℹ️  ${NAME} は存在しません"
    fi

    # Claude コンテナが残っていなければ Docker Proxy と SSH ブリッジも停止
    stop_proxy_if_idle
    stop_ssh_bridge_if_idle
    ;;

# -----------------------------------------------------------------------------
# SSH 鍵の選択（対話）/ 初期化
#   claude-dev ssh-keys          コンテナへ転送する鍵を対話選択して config に保存
#   claude-dev ssh-keys reset    選択を初期化（config 消去＋専用 agent フラッシュ/停止）
# -----------------------------------------------------------------------------
ssh-keys)
    case "${2:-}" in
        reset)
            # config の ssh_keys セクションを除去
            if [ -f "$USER_CONFIG" ]; then
                _tmp=$(mktemp)
                grep -vE '^ssh_keys:|^[[:space:]]*-[[:space:]]' "$USER_CONFIG" > "$_tmp" 2>/dev/null || true
                mv "$_tmp" "$USER_CONFIG"
            fi
            # 専用 agent の鍵をフラッシュして停止、ブリッジも停止
            if [ -S "$DEV_AGENT_SOCK" ]; then
                SSH_AUTH_SOCK="$DEV_AGENT_SOCK" ssh-add -D 2>/dev/null || true
            fi
            if [ -f "$DEV_BRIDGE_PID_FILE" ]; then
                kill "$(cat "$DEV_BRIDGE_PID_FILE" 2>/dev/null)" 2>/dev/null || true
                rm -f "$DEV_BRIDGE_PID_FILE" "$DEV_BRIDGE_PORT_FILE"
            fi
            if [ -f "$DEV_AGENT_PID_FILE" ]; then
                kill "$(cat "$DEV_AGENT_PID_FILE" 2>/dev/null)" 2>/dev/null || true
                rm -f "$DEV_AGENT_PID_FILE"
            fi
            rm -f "$DEV_AGENT_SOCK"
            echo "✅ SSH 鍵の選択をリセットしました。次回 claude-dev start で再選択します"
            ;;
        ""|select)
            select_ssh_keys_interactive
            ;;
        *)
            echo "使い方: claude-dev ssh-keys [reset]"
            exit 1
            ;;
    esac
    ;;

# -----------------------------------------------------------------------------
# ポートフォワード（動的追加）
# -----------------------------------------------------------------------------
forward)
    if [ -z "$2" ]; then
        echo "使い方: claude-dev forward <container-port> [NAME]"
        echo "例:     claude-dev forward 3000"
        exit 1
    fi
    CPORT="$2"
    if [ -n "$3" ]; then
        NAME="$3"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        exit 1
    fi

    # 既にフォワード済みか確認
    FWD_NAME="fwd-${NAME}-${CPORT}"
    if is_running "$FWD_NAME"; then
        _hport=$(docker port "$FWD_NAME" "$CPORT" 2>/dev/null | head -1 | sed 's/.*://')
        echo "ℹ️  既にフォワード済み: host:${_hport} → ${NAME}:${CPORT}"
        echo "   ブラウザで http://localhost:${_hport} にアクセス"
        exit 0
    fi
    if container_exists "$FWD_NAME"; then
        docker rm -f "$FWD_NAME" >/dev/null
    fi

    HPORT=$(find_available_host_port)
    docker run -d --rm \
        --name "$FWD_NAME" \
        --network "$NETWORK" \
        -p "${HPORT}:${CPORT}" \
        --entrypoint socat \
        "$IMG_CLAUDE" \
        "TCP-LISTEN:${CPORT},fork,reuseaddr" "TCP:${NAME}:${CPORT}" >/dev/null

    echo "✅ host:${HPORT} → ${NAME}:${CPORT}"
    echo "   ブラウザで http://localhost:${HPORT} にアクセス"
    ;;

# -----------------------------------------------------------------------------
# ポートフォワード解除
# -----------------------------------------------------------------------------
unforward)
    if [ -z "$2" ]; then
        echo "使い方: claude-dev unforward <container-port> [NAME]"
        exit 1
    fi
    CPORT="$2"
    if [ -n "$3" ]; then
        NAME="$3"
    else
        NAME=$(container_name)
    fi
    FWD_NAME="fwd-${NAME}-${CPORT}"
    if container_exists "$FWD_NAME"; then
        docker rm -f "$FWD_NAME" >/dev/null
        echo "✅ ${NAME}:${CPORT} のフォワードを解除しました"
    else
        echo "ℹ️  ${NAME}:${CPORT} のフォワードはありません"
    fi
    ;;

# -----------------------------------------------------------------------------
# ポートフォワード一覧
# -----------------------------------------------------------------------------
ports)
    if [ -n "$2" ]; then
        NAME="${2}"
    else
        NAME=$(container_name)
    fi

    if ! is_running "$NAME"; then
        echo "❌ ${NAME} は起動していません"
        exit 1
    fi

    echo "📡 ${NAME} のポートフォワード:"
    _has_fwd=0
    for cid in $(docker ps --filter "name=^fwd-${NAME}-" -q 2>/dev/null); do
        _has_fwd=1
        _fwd_name=$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')
        _cport="${_fwd_name##*-}"
        _hport=$(docker port "$_fwd_name" "$_cport" 2>/dev/null | head -1 | sed 's/.*://')
        [ -n "$_hport" ] && echo "   host:${_hport} → ${NAME}:${_cport}  (http://localhost:${_hport})"
    done
    [ $_has_fwd -eq 0 ] && echo "   (なし — claude-dev forward <port> で追加)"

    _url=$(get_novnc_url "$NAME")
    if [ -n "$_url" ]; then
        echo ""
        echo "🖥️  noVNC: $_url"
    fi
    ;;

# -----------------------------------------------------------------------------
# 実行中セッション一覧
# -----------------------------------------------------------------------------
list)
    echo "=== 実行中の Claude Code セッション ==="
    _has_containers=0
    for cid in $(docker ps --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q 2>/dev/null); do
        _has_containers=1
        cname=$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')
        _name="${cname}"
        _status=$(docker inspect --format '{{.State.Status}}' "$cid")
        _workspace=$(docker inspect --format '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}' "$cid")
        _novnc_url=$(get_novnc_url "$cname")
        echo ""
        echo "  NAME:      ${_name}"
        echo "  STATUS:    ${_status}"
        echo "  WORKSPACE: ${_workspace}"
        [ -n "$_novnc_url" ] && echo "  noVNC:     ${_novnc_url}"
        # フォワードコンテナを列挙
        for _fid in $(docker ps --filter "name=^fwd-${cname}-" -q 2>/dev/null); do
            _fn=$(docker inspect --format '{{.Name}}' "$_fid" | sed 's|^/||')
            _cp="${_fn##*-}"
            _hp=$(docker port "$_fn" "$_cp" 2>/dev/null | head -1 | sed 's/.*://')
            [ -n "$_hp" ] && echo "  FORWARD:   host:${_hp} → ${cname}:${_cp}  (http://localhost:${_hp})"
        done
    done
    if [ $_has_containers -eq 0 ]; then
        echo "  (実行中のセッションはありません)"
    fi

    # Docker Socket Proxy コンテナの状態
    echo ""
    echo "=== Docker Socket Proxy コンテナ ==="
    if is_running "$DOCKER_PROXY_CONTAINER"; then
        echo "  STATUS:  running"
    else
        echo "  STATUS:  stopped（claude-dev start で自動起動）"
    fi

    ;;

# -----------------------------------------------------------------------------
# Claude Code アップグレード
# -----------------------------------------------------------------------------
upgrade)
    echo "📦 Claude ベースイメージを更新中..."
    docker build --no-cache -t "$IMG_CLAUDE" \
        --target base \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude ベースイメージ更新完了"

    echo ""
    echo "📦 Claude VNC イメージを更新中..."
    docker build --no-cache -t "$IMG_CLAUDE_VNC" \
        --target vnc \
        --build-arg USERNAME="$CUSER" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.claude" "$BASE_DIR"
    echo "✅ Claude VNC イメージ更新完了"

    echo ""
    echo "📦 Docker Socket Proxy イメージを更新中..."
    docker build --no-cache -t "$IMG_DOCKER_PROXY" \
        -f "${BASE_DIR}/.devcontainer/Dockerfile.docker-proxy" "$BASE_DIR"
    echo "✅ Docker Socket Proxy イメージ更新完了"

    echo ""
    echo "   実行中のコンテナは stop → start で反映されます"
    ;;

# -----------------------------------------------------------------------------
# ファイアウォール確認
# -----------------------------------------------------------------------------
firewall)
    NAME=$(container_name)
    if ! is_running "$NAME"; then
        echo "❌ コンテナが起動していません"
        exit 1
    fi
    docker exec "$NAME" iptables -L OUTPUT -n --line-numbers
    ;;

# -----------------------------------------------------------------------------
# 全リセット
# -----------------------------------------------------------------------------
reset)
    echo "⚠️  以下を全て削除します:"
    echo "   - 全 Claude Code コンテナ"
    echo "   - Docker Socket Proxy コンテナ"
    echo "   - 認証情報・履歴ボリューム"
    echo "   - Docker イメージ"
    echo ""
    read -p "実行しますか？ (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "キャンセルしました"
        exit 0
    fi

    # プロジェクトコンテナ + フォワードコンテナ停止
    docker ps -a --filter "ancestor=$IMG_CLAUDE" --filter "ancestor=$IMG_CLAUDE_VNC" -q | xargs -r docker rm -f 2>/dev/null || true
    docker ps -a --filter "name=^fwd-" -q | xargs -r docker rm -f 2>/dev/null || true
    # Docker Socket Proxy コンテナ停止
    docker rm -f "$DOCKER_PROXY_CONTAINER" 2>/dev/null || true
    # ボリューム削除
    docker volume rm -f "$VOL_AUTH" "$VOL_HISTORY" "$VOL_CONFIG" "$VOL_CHROME" 2>/dev/null || true
    # ネットワーク削除
    docker network rm "$NETWORK" 2>/dev/null || true
    # イメージ削除
    docker rmi -f "$IMG_CLAUDE" "$IMG_CLAUDE_VNC" "$IMG_DOCKER_PROXY" 2>/dev/null || true

    echo "✅ 全リセット完了"
    ;;

# -----------------------------------------------------------------------------
# ヘルプ
# -----------------------------------------------------------------------------
help|*)
    cat << 'EOF'
claude-dev - Claude Code 安全開発環境（macOS 版）

セットアップ（初回のみ）:
  claude-dev setup               イメージビルド + インフラ構築
  claude-dev pull [TAG]          GHCR からビルド済みイメージを取得（ビルドの代わり。既定 latest）
  claude-dev login               OAuth ログイン
  claude-dev logout              認証情報を削除
  claude-dev ssh-keys [reset]    コンテナへ転送する SSH 鍵を対話選択（reset で初期化）

開発:
  claude-dev start               カレントディレクトリで環境を起動（VNC + Chrome 付き）
  claude-dev start --no-vnc      Chrome / VNC なしで起動（軽量）
  claude-dev code                新しい tmux ウィンドウで Claude Code を起動
  claude-dev orchestrate [<ゴール>] [--fresh]
                                 AI オーケストレーター（壁打ち→自律実行）を起動
                                 （--fresh で前回の実行状態を破棄し壁打ちから再開）
  claude-dev attach [NAME]       既存セッションに接続
  claude-dev stop [NAME]         セッションを停止
  claude-dev list                実行中セッション一覧

ポートフォワード:
  claude-dev forward <PORT> [NAME]    ポートを動的に追加
  claude-dev unforward <PORT> [NAME]  ポートフォワード解除
  claude-dev ports [NAME]             ポートフォワード一覧

メンテナンス:
  claude-dev upgrade             全イメージを更新（--no-cache 再ビルド）
  claude-dev firewall            ファイアウォールルール確認
  claude-dev reset               全削除（コンテナ・ボリューム・イメージ）

使い方:
  cd ~/repos/my-project && claude-dev start

  デフォルトでは VNC + Chrome 付きコンテナが起動します。
  --no-vnc を指定すると Chrome / VNC なしの軽量コンテナで起動します。
  VNC ありの場合、noVNC URL は起動時に表示され、手元のブラウザで直接開けます。
  日本語入力は Super+Space で切り替え（IBus-Mozc）。

  ※ VM/KVM モード（--vm / --kvm）は macOS では非対応です。

[NAME] について:
  NAME はプロジェクトのディレクトリ名です。
  省略するとカレントディレクトリから自動判定します。
  claude-dev list で実行中セッションの NAME を確認できます。

Web アプリへのアクセス（macOS はローカルなので直結）:
  1. claude-dev start           → コンテナ起動
  2. claude-dev forward 3000    → ポートフォワードを動的追加（ホスト側ポートは自動割当）
  3. ブラウザで http://localhost:<host-port> にアクセス
EOF
    ;;
esac
